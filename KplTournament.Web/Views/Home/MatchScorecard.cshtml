@*@model Match
@{
    ViewData["Title"] = "Scorecard";
    var batting = ViewBag.Batting as List<BattingScore> ?? new();
    var bowling = ViewBag.Bowling as List<BowlingScore> ?? new();
}
<section class="card">
    <h1>@Model.TeamA?.Name vs @Model.TeamB?.Name</h1>
    <p><strong>Toss:</strong> @Model.TossWinner chose to @Model.TossDecision</p>
    <p><strong>Score:</strong> @Model.TeamA?.ShortName @Model.TeamAScore/@Model.TeamAWickets (@Model.TeamAOvers) | @Model.TeamB?.ShortName @Model.TeamBScore/@Model.TeamBWickets (@Model.TeamBOvers)</p>
    <p><strong>Result:</strong> @Model.Result</p>
    <p><strong>Man of the Match:</strong> @Model.ManOfTheMatchPlayer?.Name</p>
</section>
<div class="grid two">
    <section class="card">
        <h2>Batting Scorecard</h2>
        <table>
            <thead><tr><th>Player</th><th>Team</th><th>R</th><th>B</th><th>4s</th><th>6s</th><th>Out</th></tr></thead>
            <tbody>
            @foreach (var item in batting)
            {
                <tr><td>@item.Player?.Name</td><td>@item.Team?.ShortName</td><td>@item.Runs</td><td>@item.Balls</td><td>@item.Fours</td><td>@item.Sixes</td><td>@(item.IsOut ? "Yes" : "No")</td></tr>
            }
            </tbody>
        </table>
    </section>
    <section class="card">
        <h2>Bowling Scorecard</h2>
        <table>
            <thead><tr><th>Player</th><th>Team</th><th>O</th><th>R</th><th>W</th><th>M</th></tr></thead>
            <tbody>
            @foreach (var item in bowling)
            {
                <tr><td>@item.Player?.Name</td><td>@item.Team?.ShortName</td><td>@item.Overs</td><td>@item.RunsGiven</td><td>@item.Wickets</td><td>@item.Maidens</td></tr>
            }
            </tbody>
        </table>
    </section>
</div>
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="actions">
        <a class="btn" asp-controller="Admin" asp-action="AddBatting" asp-route-matchId="@Model.Id">Add Batting Row</a>
        <a class="btn secondary" asp-controller="Admin" asp-action="AddBowling" asp-route-matchId="@Model.Id">Add Bowling Row</a>
    </div>
}*@





