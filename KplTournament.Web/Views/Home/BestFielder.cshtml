@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Best Fielder";
    int rank = 1;
}

<section class="fielder-award-page">
    <div class="fielder-award-hero">
        <div class="hero-content">
           
            <h1>Best Fielder</h1>
            <p>Top 5 fielders of CricZone Tournament</p>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        var leader = Model.First();

        <div class="fielder-leader-showcase">
            <div class="fielder-leader-left">
                <div class="fielder-leader-medal">#1</div>
                <div>
                    
                    <h2>@leader.PlayerName</h2>
                    <p>Leading the fielding chart</p>
                </div>
            </div>

            <div class="fielder-leader-stats">
                <div>
                    <strong>@leader.FieldingPoints</strong>
                    <small>Points</small>
                </div>
                <div>
                    <strong>@leader.Catches</strong>
                    <small>Catches</small>
                </div>
                <div>
                    <strong>@leader.RunOuts</strong>
                    <small>Run Outs</small>
                </div>
            </div>
        </div>

        <div class="fielder-table-card">
            <table class="fielder-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Player</th>
                        <th>Catches</th>
                        <th>Run Outs</th>
                        <th>Stumpings</th>
                        <th>Direct Hits</th>
                        <th>Points</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var player in Model)
                    {
                        <tr class="@(rank == 1 ? "fielder-top-row" : "")">
                            <td><span class="fielder-rank-badge">@rank</span></td>
                            <td class="fielder-player-name">@player.PlayerName</td>
                            <td>@player.Catches</td>
                            <td>@player.RunOuts</td>
                            <td>@player.Stumpings</td>
                            <td>@player.DirectHits</td>
                            <td class="fielder-points">@player.FieldingPoints</td>
                        </tr>

                        rank++;
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="fielder-empty-card">
            <h2>No fielding data available</h2>
            <p>Best Fielder standings will appear after match scoring starts.</p>
        </div>
    }
</section>

<style>
    body {
        margin: 0;
    }

    /* PAGE BACKGROUND */
    .fielder-award-page {
        min-height: calc(100vh - 80px);
        padding: 12px 16px 26px;
        background: linear-gradient(rgba(0,0,0,.70), rgba(0,0,0,.70)), url('/images/stadium.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    /* HERO */
    .fielder-award-hero {
        max-width: 1050px;
        margin: 0 auto 12px;
        padding: 24px 30px;
        min-height: 130px;
        border-radius: 22px;
        background: linear-gradient(135deg, rgba(139,91,86,.35), rgba(18,32,43,.45));
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
        text-align: center;
        border: 1px solid rgba(255,255,255,.10);
    }

    .fielder-award-chip {
        display: inline-flex;
        padding: 7px 16px;
        border-radius: 999px;
        background: rgba(255,255,255,.18);
        color: #fbbf24;
        font-weight: 900;
        margin-bottom: 10px;
        font-size: 14px;
    }

    .fielder-award-hero h1 {
        margin: 0;
        font-size: 36px;
        font-weight: 900;
        color: #f9fafb;
    }

    .fielder-award-hero p {
        margin: 7px 0 0;
        font-size: 15px;
        color: rgba(255,255,255,.85);
        font-weight: 700;
    }

    /* LEADER CARD */
    .fielder-leader-showcase {
        max-width: 1050px;
        margin: 0 auto 12px;
        padding: 14px 20px;
        border-radius: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        background: linear-gradient(135deg, rgba(139,91,86,.30), rgba(18,32,43,.50));
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
        color: #ffffff;
        border: 1px solid rgba(255,255,255,.10);
    }

    .fielder-leader-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .fielder-leader-medal {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #fb923c, #facc15);
        color: #111827;
        font-size: 17px;
        font-weight: 900;
    }

    .fielder-leader-left span {
        color: #fbbf24;
        font-size: 14px;
        font-weight: 800;
    }

    .fielder-leader-left h2 {
        margin: 3px 0;
        font-size: 26px;
        font-weight: 900;
        color: #ffffff;
    }

    .fielder-leader-left p {
        margin: 0;
        color: rgba(255,255,255,.85);
        font-size: 14px;
        font-weight: 700;
    }

    /* STATS */
    .fielder-leader-stats {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

        .fielder-leader-stats div {
            min-width: 70px;
            padding: 10px 12px;
            border-radius: 16px;
            text-align: center;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.12);
        }

        .fielder-leader-stats strong {
            display: block;
            font-size: 20px;
            color: #fbbf24;
            font-weight: 900;
        }

        .fielder-leader-stats small {
            color: #ffffff;
            font-size: 13px;
            font-weight: 700;
        }

    /* TABLE CARD */
    .fielder-table-card {
        max-width: 1050px;
        margin: 0 auto;
        overflow-x: auto;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(60,40,35,.45), rgba(10,20,35,.70));
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
    }

    /* TABLE */
    .fielder-table {
        width: 100%;
        min-width: 820px;
        border-collapse: collapse;
    }

        .fielder-table thead tr {
            background: linear-gradient(90deg, #1a2433 0%, #223553 32%, #3b2a32 58%, #5a2416 78%, #7a2a14 100%);
        }

        .fielder-table th {
            padding: 11px 18px;
            background: transparent;
            border: none;
            color: #f9fafb;
            font-size: 15px;
            font-weight: 800;
            text-align: left;
        }

        .fielder-table td {
            padding: 11px 18px;
            background: rgba(15,23,42,.55);
            border-bottom: 1px solid rgba(255,255,255,.10);
            font-size: 15px;
            font-weight: 700;
            color: #e5e7eb;
        }

        .fielder-table tbody tr:hover td {
            background: rgba(255,255,255,.10);
        }

    .fielder-top-row td {
        background: rgba(251,191,36,.14) !important;
    }

    /* RANK BADGE */
    .fielder-rank-badge {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        display: inline-grid;
        place-items: center;
        background: rgba(255,255,255,0.18);
        color: #ffffff;
        font-weight: 800;
        font-size: 14px;
    }

    .fielder-top-row .fielder-rank-badge {
        background: linear-gradient(135deg, #fb923c, #facc15);
        color: #111827;
    }

    /* TEXT */
    .fielder-player-name {
        color: #ffffff;
        font-weight: 800;
        font-size: 15px;
    }

    .fielder-points {
        color: #fbbf24 !important;
        font-weight: 800;
        font-size: 15px !important;
    }

    /* EMPTY CARD */
    .fielder-empty-card {
        max-width: 1050px;
        margin: 0 auto;
        padding: 28px;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(139,91,86,.30), rgba(18,32,43,.50));
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        color: #ffffff;
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
        border: 1px solid rgba(255,255,255,.10);
    }

        .fielder-empty-card h2 {
            margin: 0 0 8px;
            color: #ffffff;
        }

        .fielder-empty-card p {
            margin: 0;
            color: rgba(255,255,255,.85);
        }

    /* MOBILE */
    @@media (max-width: 768px) {
        .fielder-award-page {
            padding: 10px;
        }

        .fielder-award-hero {
            padding: 22px 20px;
            min-height: auto;
        }

            .fielder-award-hero h1 {
                font-size: 34px;
            }

        .fielder-leader-showcase {
            flex-direction: column;
            align-items: flex-start;
        }

        .fielder-leader-stats {
            width: 100%;
        }

            .fielder-leader-stats div {
                flex: 1;
            }
    }
</style>
