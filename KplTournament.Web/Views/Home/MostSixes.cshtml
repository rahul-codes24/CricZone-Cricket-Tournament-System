@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Most Sixes";
    int rank = 1;
}

<section class="sixes-award-page">
    <div class="sixes-award-hero">
        <div class="hero-content">
           
            <h1>Most Sixes</h1>
            <p>Top six hitters of CricZone Tournament</p>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        var leader = Model.First();

        <div class="sixes-leader-showcase">
            <div class="sixes-leader-left">
                <div class="sixes-leader-medal">#1</div>
                <div>
                   
                    <h2>@leader.PlayerName</h2>
                    <p>Leading the six-hitting chart</p>
                </div>
            </div>

            <div class="sixes-leader-stats">
                <div>
                    <strong>@leader.Sixes</strong>
                    <small>Sixes</small>
                </div>
                <div>
                    <strong>@leader.Runs</strong>
                    <small>Runs</small>
                </div>
                <div>
                    <strong>@leader.Balls</strong>
                    <small>Balls</small>
                </div>
            </div>
        </div>

        <div class="sixes-table-card">
            <table class="sixes-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Player</th>
                        <th>Sixes</th>
                        <th>Runs</th>
                        <th>Balls</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var player in Model)
                    {
                        <tr class="@(rank == 1 ? "sixes-top-row" : "")">
                            <td><span class="sixes-rank-badge">@rank</span></td>
                            <td class="sixes-player-name">@player.PlayerName</td>
                            <td class="sixes-value"><strong>@player.Sixes</strong></td>
                            <td>@player.Runs</td>
                            <td>@player.Balls</td>
                        </tr>

                        rank++;
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="sixes-empty-card">
            <h2>No sixes data available</h2>
            <p>Most Sixes standings will appear after match scoring starts.</p>
        </div>
    }
</section>

<style>
    body {
        margin: 0;
    }

    .sixes-award-page {
        min-height: calc(100vh - 80px);
        padding: 12px 16px 26px;
        background: linear-gradient(rgba(0,0,0,.70), rgba(0,0,0,.70)), url('/images/stadium.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .sixes-award-hero {
        max-width: 1050px;
        margin: 0 auto 12px;
        padding: 24px 30px;
        min-height: 130px;
        border-radius: 22px;
        background: linear-gradient(135deg, rgba(139,91,86,.35), rgba(18,32,43,.45));
        backdrop-filter: blur(30px);
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
        text-align: center;
    }

    .sixes-award-chip {
        display: none;
    }

    .sixes-award-hero h1 {
        margin: 0;
        font-size: 36px;
        font-weight: 900;
        color: #f9fafb;
    }

    .sixes-award-hero p {
        margin: 7px 0 0;
        font-size: 15px;
        color: rgba(255,255,255,.85);
        font-weight: 700;
    }

    .sixes-leader-showcase {
        max-width: 1050px;
        margin: 0 auto 12px;
        padding: 14px 20px;
        border-radius: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        background: linear-gradient(135deg, rgba(139,91,86,.30), rgba(18,32,43,.50));
        backdrop-filter: blur(30px);
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
        color: #ffffff;
    }

    .sixes-leader-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .sixes-leader-medal {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #fb923c, #facc15);
        color: #111827;
        font-size: 17px;
        font-weight: 900;
    }

    .sixes-leader-left span {
        color: #fbbf24;
        font-size: 14px;
        font-weight: 800;
    }

    .sixes-leader-left h2 {
        margin: 3px 0;
        font-size: 26px;
        font-weight: 900;
        color: #ffffff;
    }

    .sixes-leader-left p {
        margin: 0;
        color: rgba(255,255,255,.85);
        font-size: 14px;
        font-weight: 700;
    }

    .sixes-leader-stats {
        display: flex;
        gap: 10px;
    }

        .sixes-leader-stats div {
            min-width: 70px;
            padding: 10px 12px;
            border-radius: 16px;
            text-align: center;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.12);
        }

        .sixes-leader-stats strong {
            display: block;
            font-size: 20px;
            color: #fbbf24;
            font-weight: 900;
        }

        .sixes-leader-stats small {
            color: #ffffff;
            font-size: 13px;
            font-weight: 700;
        }

    .sixes-table-card {
        max-width: 1050px;
        margin: 0 auto;
        overflow-x: auto;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(60,40,35,.45), rgba(10,20,35,.70));
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
    }

    .sixes-table {
        width: 100%;
        min-width: 760px;
        border-collapse: collapse;
    }

        .sixes-table thead tr {
            background: linear-gradient(90deg, #1a2433 0%, #223553 32%, #3b2a32 58%, #5a2416 78%, #7a2a14 100%);
        }

        .sixes-table th {
            padding: 11px 18px;
            background: transparent;
            border: none;
            color: #f9fafb;
            font-size: 15px;
            font-weight: 800;
            text-align: left;
        }

        .sixes-table td {
            padding: 11px 18px;
            background: rgba(15,23,42,.55);
            border-bottom: 1px solid rgba(255,255,255,.10);
            font-size: 15px;
            font-weight: 700;
            color: #e5e7eb;
        }

        .sixes-table tbody tr:hover td {
            background: rgba(255,255,255,.10);
        }

    .sixes-top-row td {
        background: rgba(15,23,42,.55) !important;
    }

    .sixes-rank-badge {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        display: inline-grid;
        place-items: center;
        background: rgba(255,255,255,0.18);
        color: #ffffff;
        font-weight: 800;
        font-size: 14px;
    }

    .sixes-top-row .sixes-rank-badge {
        background: rgba(255,255,255,0.18);
        color: #ffffff;
    }

    .sixes-player-name {
        color: #ffffff;
        font-weight: 800;
        font-size: 15px;
    }

    .sixes-value {
        color: #fbbf24;
        font-weight: 800;
        font-size: 15px;
    }

    .sixes-empty-card {
        max-width: 1050px;
        margin: 0 auto;
        padding: 30px;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(60,40,35,.45), rgba(10,20,35,.70));
        backdrop-filter: blur(30px);
        color: #ffffff;
    }

    @@media (max-width: 768px) {
        .sixes-award-page {
            padding: 10px;
        }

        .sixes-leader-showcase {
            flex-direction: column;
            align-items: flex-start;
        }

        .sixes-leader-stats {
            width: 100%;
        }

            .sixes-leader-stats div {
                flex: 1;
            }
    }
</style>
