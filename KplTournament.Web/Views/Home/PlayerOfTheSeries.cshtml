@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Player of the Series";
    int rank = 1;
}

<section class="series-award-page">

    <div class="series-award-hero">
        <div class="hero-content">
            <h1>Player of the Series</h1>
            <p>Most impactful player across the whole tournament</p>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        var leader = Model.First();

        <div class="series-leader-showcase">
            <div class="series-leader-left">
                <div class="series-leader-medal">#1</div>
                <div>
                    <h2>@leader.PlayerName</h2>
                    <p>Series Impact Score: @(((double)leader.Score).ToString("0")) </p>
                </div>
            </div>

            <div class="series-leader-stats">
                <div>
                    <strong>@leader.Runs</strong>
                    <small>Runs</small>
                </div>
                <div>
                    <strong>@leader.Wickets</strong>
                    <small>Wickets</small>
                </div>
                <div>
                    <strong>@leader.Catches</strong>
                    <small>Catches</small>
                </div>
                <div>
                    <strong>@leader.MomCount</strong>
                    <small>MOM Awards</small>
                </div>
            </div>
        </div>

        <div class="series-table-card">
            <table class="series-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Player</th>
                        <th>Matches</th>
                        <th>Runs</th>
                        <th>Wickets</th>
                        <th>Catches</th>
                        <th>MOM</th>
                        <th>Score</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var player in Model)
                    {
                        <tr>
                            <td><span class="series-rank-badge">@rank</span></td>
                            <td class="series-player-name">
                                <a asp-controller="Home" asp-action="PlayerCareerStats" asp-route-id="@player.PlayerId">@player.PlayerName</a>
                            </td>
                            <td>@player.Matches</td>
                            <td>@player.Runs</td>
                            <td>@player.Wickets</td>
                            <td>@player.Catches</td>
                            <td>@player.MomCount</td>
                            <td class="series-score">@(((double)player.Score).ToString("0"))</td>
                        </tr>

                        rank++;
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="series-empty-card">
            <h2>No data available yet</h2>
            <p>Player of the Series standings will appear once matches have been played.</p>
        </div>
    }
</section>

<style>
    body {
        margin: 0;
    }

    .series-award-page {
        min-height: calc(100vh - 80px);
        padding: 12px 16px 26px;
        background: linear-gradient(rgba(0,0,0,.70), rgba(0,0,0,.70)), url('/images/stadium.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .series-award-hero {
        max-width: 1050px;
        margin: 0 auto 12px;
        padding: 24px 30px;
        min-height: 130px;
        border-radius: 22px;
        background: linear-gradient(135deg, rgba(139,91,86,.35), rgba(18,32,43,.45));
        backdrop-filter: blur(30px);
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
        text-align: center;
    }

        .series-award-hero h1 {
            margin: 0;
            font-size: 36px;
            font-weight: 900;
            color: #f9fafb;
        }

        .series-award-hero p {
            margin: 7px 0 0;
            font-size: 15px;
            color: rgba(255,255,255,.85);
            font-weight: 700;
        }

    .series-leader-showcase {
        max-width: 1050px;
        margin: 0 auto 12px;
        padding: 14px 20px;
        border-radius: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        background: linear-gradient(135deg, rgba(139,91,86,.30), rgba(18,32,43,.50));
        backdrop-filter: blur(30px);
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
        color: #ffffff;
    }

    .series-leader-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .series-leader-medal {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #fb923c, #facc15);
        color: #111827;
        font-size: 17px;
        font-weight: 900;
    }

    .series-leader-left h2 {
        margin: 3px 0;
        font-size: 26px;
        font-weight: 900;
        color: #ffffff;
    }

    .series-leader-left p {
        margin: 0;
        color: rgba(255,255,255,.85);
        font-size: 14px;
        font-weight: 700;
    }

    .series-leader-stats {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

        .series-leader-stats div {
            min-width: 70px;
            padding: 10px 12px;
            border-radius: 16px;
            text-align: center;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.12);
        }

        .series-leader-stats strong {
            display: block;
            font-size: 20px;
            color: #fbbf24;
            font-weight: 900;
        }

        .series-leader-stats small {
            color: #ffffff;
            font-size: 13px;
            font-weight: 700;
        }

    .series-table-card {
        max-width: 1050px;
        margin: 0 auto;
        overflow-x: auto;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(60,40,35,.45), rgba(10,20,35,.70));
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
    }

    .series-table {
        width: 100%;
        min-width: 820px;
        border-collapse: collapse;
    }

        .series-table thead tr {
            background: linear-gradient(90deg, #1a2433 0%, #223553 32%, #3b2a32 58%, #5a2416 78%, #7a2a14 100%);
        }

        .series-table th {
            padding: 11px 18px;
            background: transparent;
            border: none;
            color: #f9fafb;
            font-size: 15px;
            font-weight: 800;
            text-align: left;
        }

        .series-table td {
            padding: 11px 18px;
            background: rgba(15,23,42,.55);
            border-bottom: 1px solid rgba(255,255,255,.10);
            font-size: 15px;
            font-weight: 700;
            color: #e5e7eb;
        }

        .series-table tbody tr:hover td {
            background: rgba(255,255,255,.10);
        }

    .series-rank-badge {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        display: inline-grid;
        place-items: center;
        background: rgba(255,255,255,0.18);
        color: #ffffff;
        font-weight: 800;
        font-size: 14px;
    }

    .series-player-name a {
        color: #ffffff;
        font-weight: 800;
        font-size: 15px;
        text-decoration: none;
    }

        .series-player-name a:hover {
            text-decoration: underline;
        }

    .series-score {
        color: #fbbf24 !important;
        font-weight: 800;
        font-size: 15px;
    }

    .series-empty-card {
        max-width: 1050px;
        margin: 0 auto;
        padding: 40px 20px;
        text-align: center;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(60,40,35,.45), rgba(10,20,35,.70));
        backdrop-filter: blur(30px);
        color: #ffffff;
    }

    @@media (max-width: 768px) {
        .series-award-page {
            padding: 10px;
        }

        .series-leader-showcase {
            flex-direction: column;
            align-items: flex-start;
        }

        .series-leader-stats {
            width: 100%;
        }

            .series-leader-stats div {
                flex: 1;
            }
    }
</style>

