
@model List<KplTournament.Web.Models.Team>

@{
    ViewData["Title"] = "Teams";
}

<section class="hero">
    <h1>Teams</h1>
   
</section>

<div class="team-row">
    @foreach (var team in Model)
    {
        <div class="team-box">

            @if (!string.IsNullOrWhiteSpace(team.LogoPath))
            {
                <img src="@team.LogoPath" alt="@team.Name" class="team-logo" />
            }
            else if (team.Name.ToUpper() == "DAKKHAN TIGERS")
            {
                <img src="~/images/teams/dakkhan.png" alt="Dakkhan Tigers" class="team-logo" />
            }
            else if (team.Name.ToUpper() == "MARATHA ELEVEN")
            {
                <img src="~/images/teams/maratha.png" alt="Maratha Eleven" class="team-logo" />
            }
            else if (team.Name.ToUpper() == "SWARAJYA FIGHTERS")
            {
                <img src="~/images/teams/swarajya.png" alt="Swarajya Fighters" class="team-logo" />
            }
            else if (team.Name.ToUpper() == "SHIVNERI WARRIORS")
            {
                <img src="~/images/teams/shivneri.png" alt="Shivneri Warriors" class="team-logo" />
            }
            else if (team.Name.ToUpper() == "HINDAVI HITTERS")
            {
                <img src="~/images/teams/hindavi.png" alt="Hindavi Hitters" class="team-logo" />
            }
            else
            {
                <div class="team-logo team-logo-placeholder">
                    @team.ShortName
                </div>
            }

            <h2>@team.Name</h2>

            <p class="team-info">
                <strong>Owner:</strong> @team.OwnerName
            </p>

            <ul class="player-list">
                @if (team.Players != null && team.Players.Any())
                {
                    @foreach (var player in team.Players
                        .OrderByDescending(p => p.IsCaptain)
                        .ThenByDescending(p => p.IsViceCaptain)
                        .ThenBy(p => p.Name))
                    {
                        <li>
                            @if (!string.IsNullOrWhiteSpace(player.PhotoPath))
                            {
                                <img src="@player.PhotoPath" alt="@player.Name" class="player-avatar" />
                            }
                            else
                            {
                                <span class="player-avatar player-avatar-placeholder">@player.Name.Substring(0, 1).ToUpper()</span>
                            }
                            <a class="player-name" asp-controller="Home" asp-action="PlayerCareerStats" asp-route-id="@player.Id">@player.Name</a>

                            <span>
                                @if (player.IsCaptain)
                                {
                                    <span class="badge-c">C</span>
                                }
                                else if (player.IsViceCaptain)
                                {
                                    <span class="badge-vc">VC</span>
                                }
                            </span>
                        </li>
                    }
                }
                else
                {
                    <li>
                        <span>No players added</span>
                    </li>
                }
            </ul>
        </div>
    }
</div>
<style>
/* =========================
PREMIUM TEAMS PAGE
========================= */

/* PAGE BACKGROUND */

body {
margin: 0;

background:
linear-gradient(
rgba(6, 10, 20, 0.78),
rgba(6, 10, 20, 0.82)
),
url('/images/stadium.png');

background-size: cover;
background-position: center;
background-repeat: no-repeat;
background-attachment: fixed;
}

/* =========================
HERO SECTION
========================= */

.hero {
width: 88%;
max-width: 1250px;

margin: 20px auto 18px;

padding: 18px;

border-radius: 22px;

text-align: center;

background:
linear-gradient(
180deg,
rgba(139, 91, 86, .55),
rgba(18, 32, 43, .78)
) !important;

backdrop-filter: blur(28px);
-webkit-backdrop-filter: blur(28px);

box-shadow:
0 20px 50px rgba(0,0,0,.45);

border: 1px solid rgba(255,255,255,.06);
}

.hero h1 {
margin: 0;

color: #ffffff;

font-size: 42px;
font-weight: 1000;

letter-spacing: .5px;

text-shadow:
0 4px 16px rgba(0,0,0,.65);
}

/* =========================
TEAM GRID
========================= */

.team-row {
width: 88%;
max-width: 1250px;

margin: 0 auto 28px;

display: grid;

grid-template-columns: repeat(5, minmax(0, 1fr));

gap: 14px;

align-items: start;
}

/* =========================
TEAM CARD
========================= */

.team-box {
position: relative;

overflow: hidden;

text-align: center;

border-radius: 20px;

padding: 12px 10px 14px;

background:
linear-gradient(
180deg,
rgba(139, 91, 86, .45),
rgba(18, 32, 43, .82)
) !important;

backdrop-filter: blur(24px);
-webkit-backdrop-filter: blur(24px);

border: 1px solid rgba(255,255,255,.07);

box-shadow:
0 18px 42px rgba(0,0,0,.40);

transition: all .28s ease;
}

.team-box:hover {
transform: translateY(-5px);

border-color: rgba(96,165,250,.24);

box-shadow:
0 22px 48px rgba(37,99,235,.22);
}

/* =========================
LOGO
========================= */

.team-logo,
.team-logo-placeholder {
width: 100%;
max-width: 108px;

aspect-ratio: 1 / 1;

object-fit: contain;

display: block;

margin: 0 auto 12px;

padding: 10px;

border-radius: 18px;

background:
linear-gradient(
145deg,
rgba(255,255,255,.12),
rgba(255,255,255,.05)
);

border: 1px solid rgba(255,255,255,.08);

box-shadow:
0 8px 22px rgba(0,0,0,.32);

transition: all .30s ease;
}

.team-box:hover .team-logo {
transform: scale(1.05);

box-shadow:
0 14px 30px rgba(37,99,235,.20);
}

/* PLACEHOLDER */

.team-logo-placeholder {
display: flex;
align-items: center;
justify-content: center;

font-size: 26px;
font-weight: 1000;

color: #ffffff;

background:
linear-gradient(
135deg,
rgba(37,99,235,.88),
rgba(59,130,246,.82)
);
}

/* =========================
TEAM NAME
========================= */

.team-box h2 {
margin: 6px 0 10px;

color: #ffffff;

font-size: 16px;
font-weight: 1000;

line-height: 1.3;

min-height: 38px;

text-transform: uppercase;

text-shadow:
0 3px 12px rgba(0,0,0,.75);
}

/* =========================
OWNER
========================= */

.team-info {
margin: 0 auto 12px;

padding: 8px 10px;

width: 100%;

border-radius: 999px;

background:
linear-gradient(
135deg,
rgba(96,165,250,.20),
rgba(30,41,59,.42)
);

border: 1px solid rgba(255,255,255,.07);

color: #ffffff;

font-size: 11px;
font-weight: 900;

line-height: 1.4;

text-shadow:
0 2px 8px rgba(0,0,0,.75);
}

.team-info strong {
color: #ffffff;
}

/* =========================
PLAYER LIST
========================= */

.player-list {
list-style: none;

padding: 0;
margin: 10px 0 0;

display: flex;
flex-direction: column;

gap: 7px;
}

/* PLAYER ITEM */

.player-list li {
min-height: 40px;

padding: 8px 10px;

border-radius: 13px;

display: flex;
justify-content: space-between;
align-items: center;

gap: 8px;

background:
linear-gradient(
180deg,
rgba(255,255,255,.10),
rgba(255,255,255,.04)
);

border: 1px solid rgba(255,255,255,.05);

color: #ffffff;

font-size: 12px;
font-weight: 850;

backdrop-filter: blur(12px);

text-shadow:
0 2px 8px rgba(0,0,0,.75);

transition: all .22s ease;
}

.player-list li:hover {
background:
linear-gradient(
135deg,
rgba(59,130,246,.22),
rgba(30,41,59,.42)
);
}

/* PLAYER NAME */

.player-name {
flex: 1;

text-align: left;

line-height: 1.3;

color: #ffffff;

font-weight: 850;
text-decoration: none;
}

.player-name:hover {
color: #60a5fa;
}

/* PLAYER AVATAR */

.player-avatar {
width: 28px;
height: 28px;
border-radius: 50%;
object-fit: cover;
flex-shrink: 0;
border: 1px solid rgba(255,255,255,.25);
}

.player-avatar-placeholder {
display: flex;
align-items: center;
justify-content: center;
background: linear-gradient(135deg, #fbbf24, #f59e0b);
color: #1a1200;
font-weight: 900;
font-size: 12px;
}

/* =========================
BADGES
========================= */

.badge-c,
.badge-vc {
min-width: 26px;
height: 26px;

padding: 0 8px;

border-radius: 999px;

display: inline-flex;
align-items: center;
justify-content: center;

font-size: 10px;
font-weight: 1000;

box-shadow:
0 4px 12px rgba(0,0,0,.32);
}

.badge-c {
background:
linear-gradient(
135deg,
#22c55e,
#15803d
);

color: #ffffff;
}

.badge-vc {
background:
linear-gradient(
135deg,
#f59e0b,
#d97706
);

color: #ffffff;
}

/* =========================
RESPONSIVE
========================= */

@@media (max-width: 1200px) {

.team-row {
grid-template-columns: repeat(4, minmax(0, 1fr));
}
}

@@media (max-width: 992px) {

.team-row {
grid-template-columns: repeat(3, minmax(0, 1fr));
}
}

@@media (max-width: 768px) {

.hero,
.team-row {
width: 94%;
}

.hero h1 {
font-size: 34px;
}

.team-row {
grid-template-columns: repeat(2, minmax(0, 1fr));
}

.team-box h2 {
font-size: 15px;
}
}

@@media (max-width: 576px) {

.team-row {
grid-template-columns: 1fr;
}

.hero h1 {
font-size: 28px;
}
}
</style>
