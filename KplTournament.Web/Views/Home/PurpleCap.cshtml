@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Purple Cap";
    int rank = 1;
}

<section class="purple-award-page">
    <div class="purple-award-hero">
        <div class="hero-content">
            
            <h1>Purple Cap</h1>
            <p>Top wicket takers of CricZone Tournament</p>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        var leader = Model.First();
        int leaderBalls = leader.Balls;
        string leaderOvers = $"{leaderBalls / 6}.{leaderBalls % 6}";
        double leaderEconomy = leaderBalls > 0
            ? ((double)leader.RunsGiven * 6 / leaderBalls)
            : 0;

        <div class="purple-leader-showcase">
            <div class="purple-leader-left">
                <div class="purple-leader-medal">#1</div>
                <div>
                    
                    <h2>@leader.PlayerName</h2>
                    <p>Leading the bowling chart</p>
                </div>
            </div>

            <div class="purple-leader-stats">
                <div>
                    <strong>@leader.Wickets</strong>
                    <small>Wickets</small>
                </div>
                <div>
                    <strong>@leaderOvers</strong>
                    <small>Overs</small>
                </div>
                <div>
                    <strong>@leaderEconomy.ToString("0.00")</strong>
                    <small>Eco</small>
                </div>
            </div>
        </div>

        <div class="purple-table-card">
            <table class="purple-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Bowler</th>
                        <th>Wickets</th>
                        <th>Overs</th>
                        <th>Runs</th>
                        <th>WD</th>
                        <th>NB</th>
                        <th>Eco</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bowler in Model)
                    {
                        int balls = bowler.Balls;
                        string overs = $"{balls / 6}.{balls % 6}";

                        double economy = balls > 0
                            ? ((double)bowler.RunsGiven * 6 / balls)
                            : 0;

                        <tr class="@(rank == 1 ? "purple-gold-row" : "")">
                            <td><span class="purple-rank-badge">@rank</span></td>
                            <td class="purple-player-name">@bowler.PlayerName</td>
                            <td class="purple-wickets"><strong>@bowler.Wickets</strong></td>
                            <td>@overs</td>
                            <td>@bowler.RunsGiven</td>
                            <td>@bowler.Wides</td>
                            <td>@bowler.NoBalls</td>
                            <td>@economy.ToString("0.00")</td>
                        </tr>

                        rank++;
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="purple-empty-card">
            <h2>No bowling data available</h2>
            <p>Purple Cap standings will appear after match scoring starts.</p>
        </div>
    }
</section>

<style>
    body {
        margin: 0;
    }

    /* SAME BACKGROUND AS ORANGE */
    .purple-award-page {
        min-height: calc(100vh - 80px);
        padding: 12px 16px 26px;
        background: linear-gradient(rgba(0,0,0,.70), rgba(0,0,0,.70)), url('/images/stadium.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    /* HERO SAME AS ORANGE */
    .purple-award-hero {
        max-width: 1050px;
        margin: 0 auto 12px;
        padding: 24px 30px;
        min-height: 130px;
        border-radius: 22px;
        background: linear-gradient(135deg, rgba(139,91,86,.35), rgba(18,32,43,.45));
        backdrop-filter: blur(30px);
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
        text-align: center;
    }

        .purple-award-hero h1 {
            margin: 0;
            font-size: 36px;
            font-weight: 900;
            color: #f9fafb;
        }

        .purple-award-hero p {
            margin: 7px 0 0;
            font-size: 15px;
            color: rgba(255,255,255,.85);
            font-weight: 700;
        }

    /* LEADER CARD SAME */
    .purple-leader-showcase {
        max-width: 1050px;
        margin: 0 auto 12px;
        padding: 14px 20px;
        border-radius: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        background: linear-gradient(135deg, rgba(139,91,86,.30), rgba(18,32,43,.50));
        backdrop-filter: blur(30px);
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
        color: #ffffff;
    }

    .purple-leader-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .purple-leader-medal {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #7c3aed, #c084fc);
        color: #111827;
        font-size: 17px;
        font-weight: 900;
    }

    .purple-leader-left span {
        color: #c4b5fd;
        font-size: 14px;
        font-weight: 800;
    }

    .purple-leader-left h2 {
        margin: 3px 0;
        font-size: 26px;
        font-weight: 900;
        color: #ffffff;
    }

    .purple-leader-left p {
        margin: 0;
        color: rgba(255,255,255,.85);
        font-size: 14px;
        font-weight: 700;
    }

    /* STATS SAME */
    .purple-leader-stats {
        display: flex;
        gap: 10px;
    }

        .purple-leader-stats div {
            min-width: 70px;
            padding: 10px 12px;
            border-radius: 16px;
            text-align: center;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.12);
        }

        .purple-leader-stats strong {
            display: block;
            font-size: 20px;
            color: #c4b5fd;
            font-weight: 900;
        }

        .purple-leader-stats small {
            color: #ffffff;
            font-size: 13px;
            font-weight: 700;
        }

    /* TABLE SAME AS ORANGE */
    .purple-table-card {
        max-width: 1050px;
        margin: 0 auto;
        overflow-x: auto;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(60,40,35,.45), rgba(10,20,35,.70));
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 12px 28px rgba(0,0,0,.30);
    }

    .purple-table {
        width: 100%;
        min-width: 820px;
        border-collapse: collapse;
    }

        .purple-table thead tr {
            background: linear-gradient( 90deg, #1a2433 0%, #223553 32%, #3b2a32 58%, #5a2416 78%, #7a2a14 100% );
        }

        .purple-table th {
            padding: 11px 18px;
            background: transparent;
            border: none;
            color: #f9fafb;
            font-size: 15px;
            font-weight: 800;
            text-align: left;
        }

        .purple-table td {
            padding: 11px 18px;
            background: rgba(15,23,42,.55);
            border-bottom: 1px solid rgba(255,255,255,.10);
            font-size: 15px;
            font-weight: 700;
            color: #e5e7eb;
        }

        .purple-table tbody tr:hover td {
            background: rgba(255,255,255,.10);
        }

    /* BADGE */
    .purple-rank-badge {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        display: inline-grid;
        place-items: center;
        background: rgba(255,255,255,0.18);
        color: #ffffff;
        font-weight: 800;
    }

    /* TEXT */
    .purple-player-name {
        color: #ffffff;
        font-weight: 800;
    }

    .purple-wickets {
        color: #c4b5fd;
        font-weight: 800;
    }

    /* MOBILE */
    @@media (max-width: 768px) {
        .purple-award-page {
            padding: 10px;
        }

        .purple-leader-showcase {
            flex-direction: column;
            align-items: flex-start;
        }

        .purple-leader-stats {
            width: 100%;
        }

            .purple-leader-stats div {
                flex: 1;
            }
    }
</style>
