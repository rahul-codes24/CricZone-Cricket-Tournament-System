@{
    ViewData["Title"] = "Organizer Portal - CricZone";
}

<div class="login-page" style="min-height: calc(100vh - 100px); display: flex; align-items: center; justify-content: center; padding: 40px 20px; position: relative; overflow: hidden;">
    
    <!-- Unified Auth Card -->
    <div class="login-card" style="width: 100%; max-width: 530px; background: rgba(15, 23, 42, 0.55); backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px); border: 2px solid rgba(255, 255, 255, 0.08); border-radius: 32px; padding: 45px 35px; box-shadow: 0 40px 80px rgba(0, 0, 0, 0.6); position: relative; transition: all 0.3s ease;">
        
        <div class="login-header" style="text-align: center; margin-bottom: 35px;">
            <div class="login-badge" style="font-size: 34px; width: 68px; height: 68px; border-radius: 50%; background: rgba(251, 191, 36, 0.1); border: 2px solid rgba(251, 191, 36, 0.25); color: #fbbf24; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px auto; box-shadow: 0 4px 20px rgba(251, 191, 36, 0.2);">🏏</div>
            <h1 id="portal-title" style="font-size: 28px; font-weight: 900; background: linear-gradient(to right, #ffffff, #fbbf24); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 6px; letter-spacing: -0.5px;">Organizer Portal</h1>
            <p id="portal-subtitle" style="font-size: 14px; color: rgba(255, 255, 255, 0.65); font-weight: 500;">Manage CricZone tournaments with secure organizer access</p>
        </div>

        <!-- Auth Tabs (Hidden during forgot password) -->
        <div id="auth-tabs-container" class="auth-tabs" style="display: flex; background: rgba(0, 0, 0, 0.3); border-radius: 16px; padding: 5px; margin-bottom: 30px; border: 1px solid rgba(255, 255, 255, 0.05);">
            <button id="tab-login" class="auth-tab active" onclick="showTab('login')" style="flex: 1; border: none; background: none; color: #0b0f19; padding: 13px; font-size: 15px; font-weight: 800; cursor: pointer; border-radius: 12px; transition: all 0.25s ease;" type="button">Sign In</button>
            <button id="tab-signup" class="auth-tab" onclick="showTab('signup')" style="flex: 1; border: none; background: none; color: rgba(255,255,255,0.6); padding: 13px; font-size: 15px; font-weight: 800; cursor: pointer; border-radius: 12px; transition: all 0.25s ease;" type="button">Sign Up</button>
        </div>

        <!-- Success Banner -->
        @if (ViewBag.LoginSuccess != null)
        {
            <div class="login-validation" style="background: rgba(16, 185, 129, 0.15); border: 1px solid rgba(16, 185, 129, 0.3); border-radius: 14px; padding: 14px 18px; color: #a7f3d0; font-size: 13px; font-weight: 600; margin-bottom: 25px; text-align: center;">
                ✅ @ViewBag.LoginSuccess
            </div>
        }

        <!-- Validation Errors -->
        @if (ViewBag.LoginError != null)
        {
            <div class="login-validation" style="background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 14px; padding: 14px 18px; color: #fca5a5; font-size: 13px; font-weight: 600; margin-bottom: 25px; text-align: center;">
                ⚠️ @ViewBag.LoginError
            </div>
        }
        @if (ViewBag.RegisterError != null)
        {
            <div class="login-validation" style="background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 14px; padding: 14px 18px; color: #fca5a5; font-size: 13px; font-weight: 600; margin-bottom: 25px; text-align: center;">
                ⚠️ @ViewBag.RegisterError
            </div>
        }

        <!-- 1. SIGN IN FORM -->
        <form method="post" asp-action="Login" asp-controller="Account" id="form-login" class="auth-form" style="display: block;">
            @Html.AntiForgeryToken()
            
            <div class="form-group" style="margin-bottom: 24px;">
                <label style="display: block; font-size: 12px; font-weight: 800; text-transform: uppercase; color: rgba(255,255,255,0.5); letter-spacing: 1px; margin-bottom: 10px;">Mobile Number</label>
                <div style="display: flex; gap: 10px; align-items: center; justify-content: center;">
                    <select name="CountryCode" class="login-input country-select" style="width: 120px; height: 50px; padding: 0 32px 0 16px; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 14px; color: #ffffff; font-family: inherit; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.25s; cursor: pointer; box-sizing: border-box; appearance: none; -webkit-appearance: none; -moz-appearance: none; background-image: url(&quot;data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpolyline points='6 9 12 15 18 9'%3E%3C/polyline%3E%3C/svg%3E&quot;); background-repeat: no-repeat; background-position: right 14px center; background-size: 13px;">
                        <option value="+91">+91 (IN)</option>
                        <option value="+1">+1 (US/CA)</option>
                        <option value="+44">+44 (UK)</option>
                        <option value="+61">+61 (AU)</option>
                        <option value="+64">+64 (NZ)</option>
                        <option value="+27">+27 (ZA)</option>
                        <option value="+971">+971 (AE)</option>
                        <option value="+65">+65 (SG)</option>
                        <option value="+880">+880 (BD)</option>
                        <option value="+94">+94 (LK)</option>
                        <option value="+92">+92 (PK)</option>
                        <option value="+966">+966 (SA)</option>
                    </select>
                    <input type="tel" name="MobileNumber" class="login-input" placeholder="Enter 10-digit number" required pattern="\d{10}" maxlength="10" title="Mobile number must be exactly 10 digits." style="flex: 1; height: 50px; padding: 0 18px; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 14px; color: #ffffff; font-family: inherit; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.25s; box-sizing: border-box; line-height: normal;" />
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label style="display: block; font-size: 12px; font-weight: 800; text-transform: uppercase; color: rgba(255,255,255,0.5); letter-spacing: 1px; margin-bottom: 10px;">Password</label>
                <div class="input-wrap password-wrap" style="position: relative;">
                    <input type="password" id="login-password" name="Password" class="login-input" placeholder="Enter password" required style="width: 100%; height: 50px; padding: 0 70px 0 18px; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 14px; color: #ffffff; font-family: inherit; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.25s; box-sizing: border-box;" />
                    <button type="button" class="toggle-password" onclick="togglePass('login-password', this)" style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #fbbf24; font-size: 12px; font-weight: 800; cursor: pointer; outline: none;">Show</button>
                </div>
            </div>

            <!-- Forgot Password trigger link -->
            <div style="text-align: right; margin-top: -12px; margin-bottom: 24px;">
                <a href="javascript:void(0)" onclick="showForgotPassword()" style="font-size: 13px; color: #fbbf24; text-decoration: none; font-weight: 700; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Forgot Password?</a>
            </div>

            <button type="submit" class="login-btn" style="width: 100%; padding: 15px; background: linear-gradient(135deg, #10b981, #059669); border: none; border-radius: 14px; color: #ffffff; font-size: 15px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.25);">Sign In</button>
        </form>

        <!-- 2. SIGN UP FORM -->
        <form method="post" asp-action="Register" asp-controller="Account" id="form-signup" class="auth-form" style="display: none;">
            @Html.AntiForgeryToken()
            
            <div class="form-group" style="margin-bottom: 22px;">
                <label style="display: block; font-size: 12px; font-weight: 800; text-transform: uppercase; color: rgba(255,255,255,0.5); letter-spacing: 1px; margin-bottom: 10px;">Full Name</label>
                <input type="text" name="Name" class="login-input" placeholder="Enter your full name" required style="width: 100%; height: 50px; padding: 0 18px; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 14px; color: #ffffff; font-family: inherit; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.25s; box-sizing: border-box;" />
            </div>

            <div class="form-group" style="margin-bottom: 22px;">
                <label style="display: block; font-size: 12px; font-weight: 800; text-transform: uppercase; color: rgba(255,255,255,0.5); letter-spacing: 1px; margin-bottom: 10px;">Mobile Number</label>
                <div style="display: flex; gap: 10px; align-items: center; justify-content: center;">
                    <select name="CountryCode" class="login-input country-select" style="width: 120px; height: 50px; padding: 0 32px 0 16px; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 14px; color: #ffffff; font-family: inherit; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.25s; cursor: pointer; box-sizing: border-box; appearance: none; -webkit-appearance: none; -moz-appearance: none; background-image: url(&quot;data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpolyline points='6 9 12 15 18 9'%3E%3C/polyline%3E%3C/svg%3E&quot;); background-repeat: no-repeat; background-position: right 14px center; background-size: 13px;">
                        <option value="+91">+91 (IN)</option>
                        <option value="+1">+1 (US/CA)</option>
                        <option value="+44">+44 (UK)</option>
                        <option value="+61">+61 (AU)</option>
                        <option value="+64">+64 (NZ)</option>
                        <option value="+27">+27 (ZA)</option>
                        <option value="+971">+971 (AE)</option>
                        <option value="+65">+65 (SG)</option>
                        <option value="+880">+880 (BD)</option>
                        <option value="+94">+94 (LK)</option>
                        <option value="+92">+92 (PK)</option>
                        <option value="+966">+966 (SA)</option>
                    </select>
                    <input type="tel" name="MobileNumber" class="login-input" placeholder="Enter 10-digit number" required pattern="\d{10}" maxlength="10" title="Mobile number must be exactly 10 digits." style="flex: 1; height: 50px; padding: 0 18px; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 14px; color: #ffffff; font-family: inherit; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.25s; box-sizing: border-box; line-height: normal;" />
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 22px;">
                <label style="display: block; font-size: 12px; font-weight: 800; text-transform: uppercase; color: rgba(255,255,255,0.5); letter-spacing: 1px; margin-bottom: 10px;">Create Password</label>
                <div class="input-wrap password-wrap" style="position: relative;">
                    <input type="password" id="reg-password" name="Password" class="login-input" placeholder="Create new password" required pattern="^(?=.*[a-zA-Z])(?=.*\d)[a-zA-Z\d]{6,10}$" title="Password must be 6 to 10 characters long, mix characters and numbers, and contain no special symbols." style="width: 100%; height: 50px; padding: 0 70px 0 18px; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 14px; color: #ffffff; font-family: inherit; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.25s; box-sizing: border-box;" />
                    <button type="button" class="toggle-password" onclick="togglePass('reg-password', this)" style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #fbbf24; font-size: 12px; font-weight: 800; cursor: pointer; outline: none;">Show</button>
                </div>
                <div style="font-size: 11px; color: rgba(251, 191, 36, 0.75); margin-top: 6px; font-weight: 600; line-height: 1.3;">
                    ⚠️ Password must be 6-10 characters, mixed letters & numbers, no special symbols.
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 30px;">
                <label style="display: block; font-size: 12px; font-weight: 800; text-transform: uppercase; color: rgba(255,255,255,0.5); letter-spacing: 1px; margin-bottom: 10px;">Confirm Password</label>
                <div class="input-wrap password-wrap" style="position: relative;">
                    <input type="password" id="reg-confirm" name="ConfirmPassword" class="login-input" placeholder="Confirm password" required pattern="^(?=.*[a-zA-Z])(?=.*\d)[a-zA-Z\d]{6,10}$" title="Password must be 6 to 10 characters long, mix characters and numbers, and contain no special symbols." style="width: 100%; height: 50px; padding: 0 70px 0 18px; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 14px; color: #ffffff; font-family: inherit; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.25s; box-sizing: border-box;" />
                    <button type="button" class="toggle-password" onclick="togglePass('reg-confirm', this)" style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #fbbf24; font-size: 12px; font-weight: 800; cursor: pointer; outline: none;">Show</button>
                </div>
            </div>

            <button type="submit" class="login-btn" style="width: 100%; padding: 15px; background: linear-gradient(135deg, #fbbf24, #d97706); border: none; border-radius: 14px; color: #0b0f19; font-size: 15px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(251, 191, 36, 0.25);">Sign Up</button>
        </form>

        <!-- 3. FORGOT PASSWORD FORM -->
        <form method="post" asp-action="ForgotPassword" asp-controller="Account" id="form-forgot" class="auth-form" style="display: none;">
            @Html.AntiForgeryToken()

            <div class="form-group" style="margin-bottom: 22px;">
                <label style="display: block; font-size: 12px; font-weight: 800; text-transform: uppercase; color: rgba(255,255,255,0.5); letter-spacing: 1px; margin-bottom: 10px;">Registered Mobile Number</label>
                <div style="display: flex; gap: 10px; align-items: center; justify-content: center;">
                    <select name="CountryCode" class="login-input country-select" style="width: 120px; height: 50px; padding: 0 32px 0 16px; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 14px; color: #ffffff; font-family: inherit; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.25s; cursor: pointer; box-sizing: border-box; appearance: none; -webkit-appearance: none; -moz-appearance: none; background-image: url(&quot;data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpolyline points='6 9 12 15 18 9'%3E%3C/polyline%3E%3C/svg%3E&quot;); background-repeat: no-repeat; background-position: right 14px center; background-size: 13px;">
                        <option value="+91">+91 (IN)</option>
                        <option value="+1">+1 (US/CA)</option>
                        <option value="+44">+44 (UK)</option>
                        <option value="+61">+61 (AU)</option>
                        <option value="+64">+64 (NZ)</option>
                        <option value="+27">+27 (ZA)</option>
                        <option value="+971">+971 (AE)</option>
                        <option value="+65">+65 (SG)</option>
                        <option value="+880">+880 (BD)</option>
                        <option value="+94">+94 (LK)</option>
                        <option value="+92">+92 (PK)</option>
                        <option value="+966">+966 (SA)</option>
                    </select>
                    <input type="tel" name="MobileNumber" class="login-input" placeholder="Enter 10-digit number" required pattern="\d{10}" maxlength="10" title="Mobile number must be exactly 10 digits." style="flex: 1; height: 50px; padding: 0 18px; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 14px; color: #ffffff; font-family: inherit; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.25s; box-sizing: border-box; line-height: normal;" />
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 22px;">
                <label style="display: block; font-size: 12px; font-weight: 800; text-transform: uppercase; color: rgba(255,255,255,0.5); letter-spacing: 1px; margin-bottom: 10px;">New Password</label>
                <div class="input-wrap password-wrap" style="position: relative;">
                    <input type="password" id="forgot-password" name="NewPassword" class="login-input" placeholder="Enter new password" required pattern="^(?=.*[a-zA-Z])(?=.*\d)[a-zA-Z\d]{6,10}$" title="Password must be 6 to 10 characters long, mix characters and numbers, and contain no special symbols." style="width: 100%; height: 50px; padding: 0 70px 0 18px; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 14px; color: #ffffff; font-family: inherit; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.25s; box-sizing: border-box;" />
                    <button type="button" class="toggle-password" onclick="togglePass('forgot-password', this)" style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #fbbf24; font-size: 12px; font-weight: 800; cursor: pointer; outline: none;">Show</button>
                </div>
                <div style="font-size: 11px; color: rgba(251, 191, 36, 0.75); margin-top: 6px; font-weight: 600; line-height: 1.3;">
                    ⚠️ Password must be 6-10 characters, mixed letters & numbers, no special symbols.
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 30px;">
                <label style="display: block; font-size: 12px; font-weight: 800; text-transform: uppercase; color: rgba(255,255,255,0.5); letter-spacing: 1px; margin-bottom: 10px;">Confirm New Password</label>
                <div class="input-wrap password-wrap" style="position: relative;">
                    <input type="password" id="forgot-confirm" name="ConfirmPassword" class="login-input" placeholder="Confirm new password" required pattern="^(?=.*[a-zA-Z])(?=.*\d)[a-zA-Z\d]{6,10}$" title="Password must be 6 to 10 characters long, mix characters and numbers, and contain no special symbols." style="width: 100%; height: 50px; padding: 0 70px 0 18px; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 14px; color: #ffffff; font-family: inherit; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.25s; box-sizing: border-box;" />
                    <button type="button" class="toggle-password" onclick="togglePass('forgot-confirm', this)" style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #fbbf24; font-size: 12px; font-weight: 800; cursor: pointer; outline: none;">Show</button>
                </div>
            </div>

            <button type="submit" class="login-btn" style="width: 100%; padding: 15px; background: linear-gradient(135deg, #f59e0b, #d97706); border: none; border-radius: 14px; color: #0b0f19; font-size: 15px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(245, 158, 11, 0.25); margin-bottom: 20px;">Reset Password & Sign In</button>
            
            <div style="text-align: center;">
                <a href="javascript:void(0)" onclick="hideForgotPassword()" style="font-size: 13px; color: rgba(255,255,255,0.6); text-decoration: none; font-weight: 700;" onmouseover="this.style.color='#fbbf24'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">← Back to Sign In</a>
            </div>
        </form>

        <!-- Back to Dashboard -->
        <div style="margin-top: 30px; text-align: center; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 22px;">
            <a href="/" style="color: rgba(255,255,255,0.6); text-decoration: none; font-size: 13px; font-weight: 700; display: inline-flex; align-items: center; gap: 8px; transition: color 0.2s;" onmouseover="this.style.color='#fbbf24'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">
                ← Back to Main Dashboard
            </a>
        </div>

    </div>
</div>

<style>
    .login-input:focus {
        border-color: #fbbf24 !important;
        box-shadow: 0 0 10px rgba(251, 191, 36, 0.25) !important;
    }
    .auth-tab.active {
        background: #fbbf24 !important;
        color: #0b0f19 !important;
        box-shadow: 0 4px 12px rgba(251, 191, 36, 0.25) !important;
    }
    .login-btn:hover {
        transform: translateY(-1.5px);
        box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4) !important;
    }
    #form-signup .login-btn:hover {
        box-shadow: 0 6px 20px rgba(251, 191, 36, 0.4) !important;
    }
    #form-forgot .login-btn:hover {
        box-shadow: 0 6px 20px rgba(245, 158, 11, 0.4) !important;
    }
</style>

<script>
    function showTab(tabName) {
        document.querySelectorAll('.auth-tab').forEach(t => {
            t.classList.remove('active');
            t.style.color = 'rgba(255,255,255,0.6)';
            t.style.background = 'none';
            t.style.boxShadow = 'none';
        });
        document.querySelectorAll('.auth-form').forEach(f => f.style.display = 'none');
        
        if (tabName === 'login') {
            const tab = document.getElementById('tab-login');
            tab.classList.add('active');
            tab.style.color = '#0b0f19';
            tab.style.background = '#fbbf24';
            document.getElementById('form-login').style.display = 'block';
        } else {
            const tab = document.getElementById('tab-signup');
            tab.classList.add('active');
            tab.style.color = '#0b0f19';
            tab.style.background = '#fbbf24';
            document.getElementById('form-signup').style.display = 'block';
        }
    }

    function togglePass(inputId, btn) {
        const input = document.getElementById(inputId);
        if (input.type === "password") {
            input.type = "text";
            btn.textContent = "Hide";
        } else {
            input.type = "password";
            btn.textContent = "Show";
        }
    }

    // Toggle forgot password form view state
    function showForgotPassword() {
        document.getElementById('auth-tabs-container').style.display = 'none';
        document.querySelectorAll('.auth-form').forEach(f => f.style.display = 'none');
        document.getElementById('form-forgot').style.display = 'block';
        
        document.getElementById('portal-title').textContent = "Reset Password";
        document.getElementById('portal-subtitle').textContent = "Verify your number and configure a new password";
    }

    function hideForgotPassword() {
        document.getElementById('auth-tabs-container').style.display = 'flex';
        showTab('login');
        
        document.getElementById('portal-title').textContent = "Organizer Portal";
        document.getElementById('portal-subtitle').textContent = "Manage CricZone tournaments with secure organizer access";
    }

    // Auto-activate signup tab if there is a register validation error
    @if (ViewBag.RegisterError != null || (ViewBag.RegisterModel != null && ViewBag.RegisterModel.MobileNumber != ""))
    {
        <text>
        showTab('signup');
        </text>
    }
</script>