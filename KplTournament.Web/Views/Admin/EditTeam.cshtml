@model KplTournament.Web.Models.Team

@{
    ViewData["Title"] = "Edit Team";
}

<section class="edit-team-page">
    <div class="edit-team-card">

        <h1>Edit Team</h1>

        <form asp-action="EditTeam" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label>Team Name</label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="form-group">
                <label>Short Name</label>
                <input asp-for="ShortName" class="form-control" />
            </div>

            <div class="form-group">
                <label>Owner Name</label>
                <input asp-for="OwnerName" class="form-control" />
            </div>

            <div class="form-group">
                <label>Color</label>
                <input asp-for="PrimaryColor" type="color" class="form-control color-input" />
            </div>

            <div class="form-group">
                <label>Team Logo</label>
                <input type="file"
                       name="logoFile"
                       class="form-control file-input"
                       accept=".jpg,.jpeg,.png,.webp" />
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.LogoPath))
            {
                <div class="current-logo-box">
                    <span>Current Logo</span>
                    <img src="@Model.LogoPath"
                         alt="@Model.Name" />
                </div>
            }

            <div class="edit-actions">
                <button class="btn-update" type="submit">Update Team</button>
                <a asp-action="Teams" class="btn-cancel">Cancel</a>
            </div>
        </form>

    </div>
</section>

<style>
    /* =========================
       EDIT TEAM - TOSS STYLE
    ========================= */

    .edit-team-page {
        min-height: calc(100vh - 80px);
        padding: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.35)), url('/images/stadium.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .edit-team-card {
        width: 100%;
        max-width: 420px;
        padding: 20px 22px;
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(139, 91, 86, .72), rgba(18, 32, 43, .92));
        backdrop-filter: blur(28px);
        -webkit-backdrop-filter: blur(28px);
        border: none;
        box-shadow: 0 20px 50px rgba(0,0,0,.45);
    }

        .edit-team-card h1 {
            margin: 0 0 15px;
            text-align: center;
            color: #ffffff;
            font-size: 28px;
            font-weight: 1000;
        }

        .edit-team-card .form-group {
            margin-bottom: 10px;
        }

        .edit-team-card label {
            display: block;
            margin-bottom: 5px;
            color: #ffffff;
            font-size: 12px;
            font-weight: 800;
        }

        .edit-team-card .form-control {
            width: 100%;
            height: 36px;
            padding: 0 12px;
            border-radius: 999px;
            border: none;
            outline: none;
            background: #ffffff;
            color: #111827;
            font-size: 13px;
            font-weight: 700;
        }

        .edit-team-card .color-input {
            padding: 5px 12px;
        }

        .edit-team-card .file-input {
            padding: 6px 12px;
            font-size: 12px;
        }

    .current-logo-box {
        margin: 6px 0 10px;
        text-align: center;
    }

        .current-logo-box span {
            display: block;
            margin-bottom: 6px;
            color: rgba(255,255,255,0.85);
            font-size: 11px;
            font-weight: 800;
        }

        .current-logo-box img {
            width: 58px;
            height: 58px;
            object-fit: cover;
            border-radius: 12px;
            border: 2px solid rgba(255,255,255,0.35);
        }

    .edit-actions {
        display: flex;
        gap: 10px;
        margin-top: 10px;
    }

    .btn-update,
    .btn-cancel {
        width: 100%;
        height: 38px;
        border-radius: 999px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 900;
        cursor: pointer;
    }

    .btn-update {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        box-shadow: 0 8px 20px rgba(34,197,94,0.4);
    }

    .btn-cancel {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
    }

        .btn-update:hover,
        .btn-cancel:hover {
            transform: translateY(-2px);
            color: #ffffff;
        }

    @@media (max-width: 768px) {
        .edit-team-card {
            max-width: 320px;
            padding: 20px 16px;
        }
    }
</style>