@model KplTournament.Web.Models.Match

@{
    ViewData["Title"] = "Start Match";
}

<div class="start-match-page">
    <div class="center-stack">

        <div class="score-header-card">
            <div class="panel-body">
                <h2>Start Match</h2>
                <p><strong>Match:</strong> @Model.TeamA?.Name vs @Model.TeamB?.Name</p>
            </div>
        </div>

        <div class="dark-panel">
            <div class="panel-body">
                <form asp-action="StartMatch" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="alert-error" style="display:none;"></div>

                    <div class="form-group">
                        <label for="strikerId">Striker</label>
                        <select id="strikerId" name="strikerId" class="form-select" asp-items="ViewBag.StrikerList" required>
                            <option value="">-- Select Striker --</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="nonStrikerId">Non-Striker</label>
                        <select id="nonStrikerId" name="nonStrikerId" class="form-select" asp-items="ViewBag.NonStrikerList" required>
                            <option value="">-- Select Non-Striker --</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="bowlerId">Bowler</label>
                        <select id="bowlerId" name="bowlerId" class="form-select" asp-items="ViewBag.BowlerList" required>
                            <option value="">-- Select Bowler --</option>
                        </select>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-success">Start Live Match</button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

<style>
    .start-match-page {
        min-height: calc(100vh - 80px);
        padding: 24px 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(rgba(0,0,0,.35), rgba(0,0,0,.45)), url('/images/stadium.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

        .start-match-page .center-stack {
            width: 100%;
            max-width: 480px;
            margin: 0 auto;
        }

        .start-match-page .score-header-card,
        .start-match-page .dark-panel {
            border-radius: 24px !important;
            background: linear-gradient(180deg, rgba(139, 91, 86, .72), rgba(18, 32, 43, .92)) !important;
            backdrop-filter: blur(28px) !important;
            -webkit-backdrop-filter: blur(28px) !important;
            border: none !important;
            box-shadow: 0 20px 50px rgba(0,0,0,.45) !important;
            color: #ffffff !important;
        }

        .start-match-page .score-header-card {
            padding: 28px 26px;
            margin-bottom: 18px;
            text-align: center;
        }

        .start-match-page .dark-panel {
            padding: 28px 26px;
        }

        .start-match-page .panel-body {
            padding: 0;
        }

        .start-match-page h2 {
            margin: 0 0 18px;
            font-size: 28px;
            font-weight: 900;
            color: #ffffff;
        }

        .start-match-page p {
            margin: 0;
            font-size: 16px;
            color: rgba(255,255,255,.82);
        }

        .start-match-page strong,
        .start-match-page label {
            color: #ffffff;
            font-weight: 900;
        }

        .start-match-page .form-group {
            margin-bottom: 22px;
        }

        .start-match-page label {
            display: block;
            margin-bottom: 10px;
            font-size: 15px;
        }

        .start-match-page .form-select {
            width: 100%;
            height: 54px;
            padding: 0 22px;
            border: none !important;
            border-radius: 999px !important;
            background: #ffffff !important;
            color: #111827 !important;
            font-size: 16px;
            font-weight: 800;
            outline: none;
            box-shadow: 0 10px 24px rgba(0,0,0,.25);
        }

        .start-match-page .form-actions {
            margin-top: 8px;
        }

        .start-match-page .btn-success {
            width: 100%;
            height: 56px;
            border: none !important;
            border-radius: 999px !important;
            background: linear-gradient(135deg, #22c55e, #16a34a) !important;
            color: #ffffff !important;
            font-size: 19px;
            font-weight: 900;
            cursor: pointer;
            box-shadow: 0 16px 36px rgba(34,197,94,.38);
        }

            .start-match-page .btn-success:hover {
                transform: translateY(-2px);
                box-shadow: 0 22px 44px rgba(34,197,94,.50);
            }

        .start-match-page .alert-error {
            color: #fecaca;
            font-size: 12px;
            font-weight: 800;
            margin-bottom: 16px;
        }

    @@media (max-width: 768px) {
        .start-match-page {
            padding: 14px 10px;
            align-items: flex-start;
        }

            .start-match-page .center-stack {
                max-width: 94%;
            }

            .start-match-page .score-header-card,
            .start-match-page .dark-panel {
                padding: 22px 18px;
            }

            .start-match-page h2 {
                font-size: 22px;
            }
    }
    /* Make both boxes smaller */
    .score-header-card {
        padding: 20px 18px !important;
        border-radius: 20px !important;
    }

    .dark-panel {
        padding: 20px 18px !important;
        border-radius: 20px !important;
    }

    /* Reduce width slightly */
    .center-stack {
        max-width: 420px !important;
    }

    /* Reduce heading size */
    .score-header-card h2 {
        font-size: 22px !important;
        margin-bottom: 8px !important;
    }

    /* Reduce spacing inside form */
    .form-group {
        margin-bottom: 14px !important;
    }

    /* Reduce input size */
    .form-select {
        height: 44px !important;
        font-size: 14px !important;
    }

    /* Reduce button size */
    .btn-success {
        height: 46px !important;
        font-size: 15px !important;
    }
    /* Reduce gap between top and bottom box */
    .score-header-card {
        margin-bottom: 8px !important; /* 🔥 reduce gap */
    }

    /* Also remove extra space if any */
    .center-stack {
        gap: 0 !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}