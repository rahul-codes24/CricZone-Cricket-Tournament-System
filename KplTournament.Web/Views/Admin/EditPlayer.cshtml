@model KplTournament.Web.Models.Player

@{
    ViewData["Title"] = "Edit Player";
}

<section class="edit-player-page">
    <div class="edit-player-card">

        <h1>Edit Player</h1>

        <form asp-action="EditPlayer" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            @if (!string.IsNullOrWhiteSpace(Model.PhotoPath))
            {
                <div class="form-group" style="text-align:center;">
                    <img src="@Model.PhotoPath" alt="@Model.Name" class="player-photo-preview" />
                </div>
            }

            <div class="form-group">
                <label>Player Photo</label>
                <input type="file" name="photoFile" accept=".jpg,.jpeg,.png,.webp" class="form-control" style="padding:6px 12px; height:auto; border-radius:12px;" />
            </div>

            <div class="form-group">
                <label>Name</label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="form-group">
                <label>Role</label>
                <input asp-for="Role" class="form-control" />
            </div>

            <div class="form-group">
                <label>Team</label>
                <select asp-for="TeamId" asp-items="ViewBag.Teams" class="form-control"></select>
            </div>

            <div class="player-checks">
                <label>
                    <input type="radio" name="PlayerRoleRadio" id="radioCaptain" value="Captain" @(Model.IsCaptain ? "checked" : "") onchange="updatePlayerRoles()" />
                    Captain
                </label>

                <label>
                    <input type="radio" name="PlayerRoleRadio" id="radioViceCaptain" value="ViceCaptain" @(Model.IsViceCaptain ? "checked" : "") onchange="updatePlayerRoles()" />
                    Vice Captain
                </label>

                <label>
                    <input type="radio" name="PlayerRoleRadio" id="radioRegular" value="Regular" @(!Model.IsCaptain && !Model.IsViceCaptain ? "checked" : "") onchange="updatePlayerRoles()" />
                    Regular Player
                </label>

                <input type="hidden" asp-for="IsCaptain" id="hdnIsCaptain" />
                <input type="hidden" asp-for="IsViceCaptain" id="hdnIsViceCaptain" />
            </div>

            <div class="edit-player-actions">
                <button class="btn-update-player" type="submit">Update Player</button>
                <a asp-action="Players" class="btn-cancel-player">Cancel</a>
            </div>
        </form>

    </div>
</section>

<style>
    /* =========================
       EDIT PLAYER - TOSS STYLE
    ========================= */

    .edit-player-page {
        min-height: calc(100vh - 80px);
        padding: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.35)), url('/images/stadium.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .edit-player-card {
        width: 100%;
        max-width: 380px;
        padding: 22px 18px;
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(139,91,86,.72), rgba(18,32,43,.92));
        backdrop-filter: blur(28px);
        -webkit-backdrop-filter: blur(28px);
        border: none;
        box-shadow: 0 20px 50px rgba(0,0,0,.45);
    }

        .edit-player-card h1 {
            margin: 0 0 16px;
            text-align: center;
            color: #ffffff;
            font-size: 28px;
            font-weight: 1000;
        }

        .edit-player-card .form-group {
            margin-bottom: 12px;
        }

        .player-photo-preview {
            width: 84px;
            height: 84px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid rgba(255,255,255,.4);
            box-shadow: 0 8px 20px rgba(0,0,0,.4);
        }

        .edit-player-card label {
            display: block;
            margin-bottom: 6px;
            color: #ffffff;
            font-size: 12px;
            font-weight: 800;
        }

        .edit-player-card .form-control {
            width: 100%;
            height: 38px;
            padding: 0 12px;
            border-radius: 999px;
            border: none;
            outline: none;
            background: #ffffff;
            color: #111827;
            font-size: 13px;
            font-weight: 700;
        }

            .edit-player-card .form-control:focus {
                box-shadow: 0 0 0 3px rgba(96,165,250,.35);
            }

    .player-checks {
        display: flex;
        gap: 14px;
        margin-top: 8px;
    }

        .player-checks label {
            display: flex;
            align-items: center;
            gap: 6px;
            margin: 0;
            color: #ffffff;
            font-size: 12px;
            font-weight: 800;
        }

    .edit-player-actions {
        display: flex;
        gap: 10px;
        margin-top: 16px;
    }

    .btn-update-player,
    .btn-cancel-player {
        width: 100%;
        height: 38px;
        border-radius: 999px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 900;
        cursor: pointer;
    }

    .btn-update-player {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        box-shadow: 0 8px 20px rgba(34,197,94,.4);
    }

    .btn-cancel-player {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
    }

        .btn-update-player:hover,
        .btn-cancel-player:hover {
            transform: translateY(-2px);
            color: #ffffff;
        }

    @@media (max-width: 768px) {
        .edit-player-card {
            max-width: 320px;
            padding: 20px 16px;
        }

        .player-checks {
            flex-direction: column;
            gap: 8px;
        }
    }
</style>

<script>
    function updatePlayerRoles() {
        var isCaptain = document.getElementById('radioCaptain').checked;
        var isViceCaptain = document.getElementById('radioViceCaptain').checked;
        document.getElementById('hdnIsCaptain').value = isCaptain ? 'true' : 'false';
        document.getElementById('hdnIsViceCaptain').value = isViceCaptain ? 'true' : 'false';
    }
</script>