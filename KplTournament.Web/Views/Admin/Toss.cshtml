@model KplTournament.Web.Models.Match

@{
    ViewData["Title"] = "Toss";
}

<div class="page-center toss-page">
    <div class="center-stack">

        <div class="score-header-card toss-match-card">
            <div class="panel-body">
                <h2>@Model.TeamA?.Name vs @Model.TeamB?.Name</h2>
                <p><strong>Venue:</strong> @Model.Venue</p>
                <p><strong>Date:</strong> @Model.MatchDate.ToString("dd MMM yyyy")</p>
            </div>
        </div>

        <div class="dark-panel toss-form-card">
            <div class="panel-body">
                <form asp-action="Toss" asp-route-id="@Model.Id" method="post" class="toss-form">
                    @Html.AntiForgeryToken()

                   

                    <div class="form-group">
                        <label for="tossWinnerTeamId">Toss Winner</label>
                        <select id="tossWinnerTeamId" name="tossWinnerTeamId" class="form-select" required>
                            <option value="">-- Select Toss Winner --</option>
                            @if (ViewBag.TeamOptions != null)
                            {
                                foreach (var item in ViewBag.TeamOptions)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="tossDecision">Toss Decision</label>
                        <select id="tossDecision" name="tossDecision" class="form-select" required>
                            <option value="">-- Select Decision --</option>
                            <option value="Bat">Bat</option>
                            <option value="Bowl">Bowl</option>
                        </select>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-warning">Save Toss</button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>

    /* =========================
       TOSS PAGE BACKGROUND
    ========================= */
    .toss-page {
        min-height: calc(100vh - 80px);
        padding: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.35)), url('/images/stadium.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

        /* CENTER WIDTH SAME AS LOGIN */
        .toss-page .center-stack {
            width: 100%;
            max-width: 320px;
            margin: 0 auto;
        }

    /* =========================
       GLASS CARD (EXACT LOGIN STYLE)
    ========================= */
    .toss-match-card,
    .toss-form-card {
        width: 100%;
        border-radius: 18px;
        /* ✅ PURE GLASS (same as login) */
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(28px);
        -webkit-backdrop-filter: blur(28px);
        border: none;
        box-shadow: 0 20px 50px rgba(0,0,0,0.45);
    }

    /* SPACING */
    .toss-match-card {
        padding: 20px 16px;
        margin-bottom: 14px;
        text-align: center;
    }

    .toss-form-card {
        padding: 20px 16px;
    }

    /* =========================
       TEXT (CLEAN LIKE LOGIN)
    ========================= */
    .toss-match-card h2 {
        margin: 0 0 10px;
        font-size: 18px;
        font-weight: 1000;
        color: #ffffff;
    }

    .toss-match-card p {
        margin: 4px 0;
        font-size: 12px;
        color: rgba(255,255,255,0.7);
    }

    .toss-match-card strong {
        color: #ffffff;
    }

    /* =========================
       FORM
    ========================= */
    .toss-page .form-group {
        margin-bottom: 12px;
    }

    .toss-page label {
        font-size: 12px;
        font-weight: 700;
        color: rgba(255,255,255,0.9);
    }

    /* INPUT STYLE SAME AS LOGIN */
    .toss-page .form-select {
        width: 100%;
        height: 36px;
        padding: 0 12px;
        background: transparent;
        border: none;
        border-bottom: 1px solid rgba(255,255,255,0.5);
        color: white;
        font-size: 13px;
        outline: none;
    }

        .toss-page .form-select option {
            color: black;
        }

        /* FOCUS EFFECT */
        .toss-page .form-select:focus {
            border-bottom: 1px solid #60a5fa;
        }

    /* =========================
       BUTTON (SAME AS LOGIN)
    ========================= */
    .toss-page .form-actions {
        margin-top: 10px;
    }

    .toss-page .btn-warning {
        width: 100%;
        height: 38px;
        border-radius: 999px;
        border: none;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: white;
        font-size: 13px;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 8px 20px rgba(34,197,94,0.4);
        transition: 0.2s;
    }

        .toss-page .btn-warning:hover {
            transform: translateY(-2px);
        }

    /* =========================
       ERROR
    ========================= */
    .field-error {
        font-size: 11px;
        color: #fecaca;
    }

    /* =========================
       MOBILE
    ========================= */
    @@media (max-width: 768px) {
        .toss-page {
            padding: 10px;
        }

            .toss-page .center-stack {
                max-width: 300px;
            }
    }

</style>


<style>
    .toss-page .toss-match-card,
    .toss-page .toss-form-card {
        background: linear-gradient(180deg, rgba(139, 91, 86, .72), rgba(18, 32, 43, .92)) !important;
        backdrop-filter: blur(28px) !important;
        -webkit-backdrop-filter: blur(28px) !important;
        border: none !important;
        box-shadow: 0 20px 50px rgba(0,0,0,.45) !important;
    }

        .toss-page .toss-match-card h2,
        .toss-page .toss-match-card p,
        .toss-page label {
            color: #ffffff !important;
            text-shadow: none !important;
        }

    .toss-page .form-select {
        background: #ffffff !important;
        color: #111827 !important;
        border: none !important;
        border-radius: 999px !important;
    }
</style>