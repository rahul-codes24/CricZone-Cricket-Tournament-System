@model KplTournament.Web.Models.ViewModels.ScorecardViewModel

@{
    ViewData["Title"] = "View Scorecard";

    var innings1Balls = Model.Balls?
        .Where(x => x.InningsNumber == 1)
        .ToList() ?? new List<KplTournament.Web.Models.ViewModels.BallByBallViewModel>();

    var innings2Balls = Model.Balls?
        .Where(x => x.InningsNumber == 2)
        .ToList() ?? new List<KplTournament.Web.Models.ViewModels.BallByBallViewModel>();

    var innings1Overs = innings1Balls
        .Select(x => x.OverText.Contains('.') ? x.OverText.Substring(0, x.OverText.IndexOf('.')) : x.OverText)
        .Distinct()
        .OrderBy(x => int.TryParse(x, out var n) ? n : 0)
        .ToList();

    var innings2Overs = innings2Balls
        .Select(x => x.OverText.Contains('.') ? x.OverText.Substring(0, x.OverText.IndexOf('.')) : x.OverText)
        .Distinct()
        .OrderBy(x => int.TryParse(x, out var n) ? n : 0)
        .ToList();
}

<style>
    .scorecard-page {
        max-width: 1400px;
        margin: 20px auto;
        padding: 0 12px;
    }

    .scorecard-shell {
        background: #0f172a;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 16px 40px rgba(0,0,0,0.28);
    }

    .scorecard-top {
        background: linear-gradient(135deg, #111827, #1f2937);
        color: #fff;
        padding: 26px 28px 22px;
    }

    .scorecard-title {
        margin: 0 0 10px 0;
        font-size: 28px;
        font-weight: 800;
        line-height: 1.2;
        text-transform: uppercase;
    }

    .scorecard-result {
        font-size: 18px;
        color: #e5e7eb;
        margin: 0;
    }

    .innings-card {
        background: #ffffff;
        color: #1f2937;
        margin: 0;
        border-top: 1px solid #e5e7eb;
    }

    .innings-header {
        background: #0f9d7a;
        color: #ffffff;
        padding: 18px 26px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .innings-team {
        font-size: 22px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .3px;
    }

    .innings-score {
        font-size: 20px;
        font-weight: 800;
        white-space: nowrap;
    }

    .section-title {
        background: #f3f4f6;
        color: #1f2937;
        padding: 14px 18px;
        font-size: 16px;
        font-weight: 800;
        border-top: 1px solid #e5e7eb;
        border-bottom: 1px solid #e5e7eb;
    }

    .score-table-wrap {
        overflow-x: auto;
    }

    .score-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 760px;
    }

        .score-table th,
        .score-table td {
            padding: 14px 16px;
            border-bottom: 1px solid #e5e7eb;
            vertical-align: middle;
        }

        .score-table th {
            background: #f3f4f6;
            color: #1f2937;
            font-size: 15px;
            font-weight: 800;
            text-align: left;
        }

        .score-table td {
            background: #ffffff;
            color: #1f2937;
            font-size: 15px;
        }

        .score-table .num {
            text-align: center;
            white-space: nowrap;
        }

        .score-table .right {
            text-align: right;
        }

    .muted {
        color: #6b7280;
    }

    .strong {
        font-weight: 800;
    }

    .summary-row td {
        background: #fafafa;
        font-size: 15px;
    }

    .empty-row td {
        color: #9ca3af;
        font-style: italic;
    }

    .action-bar {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        padding: 18px 0 0;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #2563eb;
        color: #ffffff;
        text-decoration: none;
        font-weight: 700;
        padding: 10px 16px;
        border-radius: 10px;
        border: none;
