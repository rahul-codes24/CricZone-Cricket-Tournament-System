<script>
    function filterOver(inningsPrefix, selectedOver) {
        const balls = document.querySelectorAll('.' + inningsPrefix + '-ball');

        balls.forEach(ball => {
            const ballOver = ball.getAttribute('data-over');

            if (selectedOver === 'all' || ballOver === selectedOver) {
                ball.style.display = 'block';
            } else {
                ball.style.display = 'none';
            }
        });
    }
</script>