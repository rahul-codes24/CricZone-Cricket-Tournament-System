<script>
    function filterOver(inningsPrefix, selectedOver) {
        const balls = document.querySelectorAll('.' + inningsPrefix + '-ball');

        balls.forEach(ball => {
            const ballOver = ball.getAttribute('data-over');

            if (selectedOver === 'all' || ballOver === selectedOver) {
                ball.style.display = 'block';
            } else {
                ball.style.display = 'none';
            }
        });
    }
</script>*@























@model KplTournament.Web.Models.ViewModels.ScorecardViewModel

@{
    ViewData["Title"] = "View Scorecard";

    // ✅ MAN OF THE MATCH CALCULATION
    var allPlayers = new List<dynamic>();

    if (Model.Innings1?.Batting != null)
    {
        foreach (var p in Model.Innings1.Batting)
        {
            allPlayers.Add(new
            {
                Name = p.PlayerName,
                Runs = p.Runs,
                Wickets = 0,
                Score = (p.Runs * 1.0)
            });
        }
    }

    if (Model.Innings2?.Batting != null)
    {
        foreach (var p in Model.Innings2.Batting)
        {
            allPlayers.Add(new
            {
                Name = p.PlayerName,
                Runs = p.Runs,
                Wickets = 0,
                Score = (p.Runs * 1.0)
            });
        }
    }

    if (Model.Innings1?.Bowling != null)
    {
        foreach (var p in Model.Innings1.Bowling)
        {
            allPlayers.Add(new
            {
                Name = p.PlayerName,
                Runs = 0,
                Wickets = p.Wickets,
                Score = (p.Wickets * 25.0)
            });
        }
    }

    if (Model.Innings2?.Bowling != null)
    {
        foreach (var p in Model.Innings2.Bowling)
        {
            allPlayers.Add(new
            {
                Name = p.PlayerName,
                Runs = 0,
                Wickets = p.Wickets,
                Score = (p.Wickets * 25.0)
            });
        }
    }

    var bestPlayer = allPlayers
        .GroupBy(p => p.Name)
        .Select(g => new
        {
            Name = g.Key,
            TotalRuns = g.Sum(x => (int)x.Runs),
            TotalWickets = g.Sum(x => (int)x.Wickets),
            TotalScore = g.Sum(x => (double)x.Score)
        })
        .OrderByDescending(x => x.TotalScore)
        .FirstOrDefault();

    var innings1Balls = Model.Balls?
        .Where(x => x.InningsNumber == 1)
        .ToList() ?? new List<KplTournament.Web.Models.ViewModels.BallByBallViewModel>();

    var innings2Balls = Model.Balls?
        .Where(x => x.InningsNumber == 2)
        .ToList() ?? new List<KplTournament.Web.Models.ViewModels.BallByBallViewModel>();

    var innings1Overs = innings1Balls
        .Select(x => x.OverText.Contains('.') ? x.OverText.Substring(0, x.OverText.IndexOf('.')) : x.OverText)
        .Distinct()
        .OrderBy(x => int.TryParse(x, out var n) ? n : 0)
        .ToList();

    var innings2Overs = innings2Balls
        .Select(x => x.OverText.Contains('.') ? x.OverText.Substring(0, x.OverText.IndexOf('.')) : x.OverText)
        .Distinct()
        .OrderBy(x => int.TryParse(x, out var n) ? n : 0)
        .ToList();
}

