@model KplTournament.Web.Models.Tournament

@{
    ViewData["Title"] = "Create Tournament";
}

<section class="admin-page">
    <div class="admin-glass-card" style="max-width: 600px; margin: 0 auto; padding: 30px;">
        <h2 style="text-align:center; margin-bottom: 20px; font-weight:800;">Create New Tournament</h2>

        <form asp-action="CreateTournament" method="post" class="admin-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="field-error"></div>

            <div class="form-group" style="margin-bottom:15px;">
                <label asp-for="Name" style="display:block; margin-bottom:5px; font-weight:700;">Tournament Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter tournament name" required />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <div class="form-group" style="margin-bottom:15px;">
                <label asp-for="Description" style="display:block; margin-bottom:5px; font-weight:700;">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter description/rules" required></textarea>
                <span asp-validation-for="Description" class="field-error"></span>
            </div>

            <div class="form-group" style="margin-bottom:15px;">
                <label asp-for="Venue" style="display:block; margin-bottom:5px; font-weight:700;">Venue / Location</label>
                <input asp-for="Venue" class="form-control" placeholder="e.g. Village Ground, City Stadium" required />
                <span asp-validation-for="Venue" class="field-error"></span>
            </div>

            <div class="form-group" style="margin-bottom:15px; display:flex; gap:15px;">
                <div style="flex:1;">
                    <label asp-for="StartDate" style="display:block; margin-bottom:5px; font-weight:700;">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control" required />
                    <span asp-validation-for="StartDate" class="field-error"></span>
                </div>
                <div style="flex:1;">
                    <label asp-for="EndDate" style="display:block; margin-bottom:5px; font-weight:700;">End Date</label>
                    <input asp-for="EndDate" type="date" class="form-control" required />
                    <span asp-validation-for="EndDate" class="field-error"></span>
                </div>
            </div>

            <div class="form-group" style="margin-bottom:20px;">
                <label asp-for="Status" style="display:block; margin-bottom:5px; font-weight:700;">Status</label>
                <select asp-for="Status" class="form-select" required>
                    <option value="Upcoming">Upcoming</option>
                    <option value="Live">Live</option>
                    <option value="Completed">Completed</option>
                </select>
                <span asp-validation-for="Status" class="field-error"></span>
            </div>

            <div style="display:flex; gap:12px; margin-top:25px;">
                <button type="submit" class="btn btn-success" style="flex:1; padding: 12px; font-weight:700; border-radius: 8px;">Create Tournament</button>
                <a asp-action="Index" class="btn" style="flex:1; padding: 12px; font-weight:700; border-radius: 8px; text-decoration:none; text-align:center; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); color:#ffffff;">Cancel</a>
            </div>
        </form>
    </div>
</section>
