<!-- Real-time sync: if this match is being scored from another tab/device, or a viewer's
     page triggers a reconnect, keep this admin view in sync automatically. -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    (function () {
        const matchId = @Model.Id;
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/match")
            .withAutomaticReconnect()
            .build();

        // Ignore updates for a short window right after our own action, so the
        // admin's own click doesn't cause a jarring double-reload.
        let suppressUntil = Date.now() + 2000;

        connection.on("MatchUpdated", function () {
            if (Date.now() > suppressUntil) {
                window.location.reload();
            }
        });

        connection.start()
            .then(function () { return connection.invoke("JoinMatch", matchId); })
            .catch(function (err) { console.error("Live sync unavailable:", err); });
    })();
</script>