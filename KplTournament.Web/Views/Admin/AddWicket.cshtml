@*@using KplTournament.Web.Models

@{
    ViewData["Title"] = "Add Wicket";

    var match = ViewBag.Match as Match;
}

<h2>Add Wicket</h2>

@if (TempData["Error"] != null)
{
    <div style="background:#f8d7da;color:#842029;padding:12px 16px;border-radius:8px;margin-bottom:15px;">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div style="background:#d1e7dd;color:#0f5132;padding:12px 16px;border-radius:8px;margin-bottom:15px;">
        @TempData["Success"]
    </div>
}

@if (match != null)
{
    <div style="border:1px solid #ddd;padding:18px;border-radius:12px;margin-bottom:20px;background:#fafafa;">
        <h3 style="margin-top:0;">@match.TeamA?.Name vs @match.TeamB?.Name</h3>
        <p><strong>Venue:</strong> @match.Venue</p>
        <p><strong>Current Innings:</strong> @match.CurrentInnings</p>
        <p><strong>Score:</strong> @match.CurrentRuns / @match.CurrentWickets</p>
        <p><strong>Overs:</strong> @match.CurrentOver.@match.CurrentBall</p>
        <p><strong>Striker:</strong> @(match.Striker?.Name ?? "Not Selected")</p>
        <p><strong>Non-Striker:</strong> @(match.NonStriker?.Name ?? "Not Selected")</p>
        <p><strong>Bowler:</strong> @(match.CurrentBowler?.Name ?? "Not Selected")</p>
    </div>
}

<div style="border:1px solid #ddd;padding:20px;border-radius:12px;background:#fff;">
    <form asp-action="AddWicket" asp-controller="Admin" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="matchId" value="@(match?.Id ?? 0)" />

        <div style="margin-bottom:15px;">
            <label style="display:block;font-weight:600;margin-bottom:6px;">Out Batsman</label>
            <select name="outBatsmanId" asp-items="ViewBag.OutBatsmanList" class="form-control" required>
                <option value="">-- Select Out Batsman --</option>
            </select>
        </div>

        <div style="margin-bottom:15px;">
            <label style="display:block;font-weight:600;margin-bottom:6px;">Wicket Type</label>
            <select name="wicketType" id="wicketType" asp-items="ViewBag.WicketTypeList" class="form-control" required>
                <option value="">-- Select Wicket Type --</option>
            </select>
        </div>

        <div id="fielderSection" style="margin-bottom:15px;">
            <label style="display:block;font-weight:600;margin-bottom:6px;">Fielder</label>
            <select name="fielderId" asp-items="ViewBag.FielderList" class="form-control">
                <option value="">-- Select Fielder --</option>
            </select>
            <small style="color:#666;">
                Required for Caught, Run Out, Stumped, and Caught Behind.
            </small>
        </div>

        <div id="nextBatsmanSection" style="margin-bottom:15px;">
            <label style="display:block;font-weight:600;margin-bottom:6px;">Next Batsman</label>
            <select name="nextBatsmanId" asp-items="ViewBag.NextBatsmanList" class="form-control">
                <option value="">-- Select Next Batsman --</option>
            </select>
            <small style="color:#666;">
                Select the new batsman who will come after the wicket.
            </small>
        </div>

        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:20px;">
            <button type="submit" class="btn btn-danger">Save Wicket</button>

            @if (match != null)
            {
                <a asp-action="LiveScoring" asp-route-id="@match.Id" class="btn btn-secondary">Back to Live Scoring</a>
            }
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const wicketType = document.getElementById("wicketType");
        const fielderSection = document.getElementById("fielderSection");

        function toggleFielderSection() {
            const value = wicketType.value;

            if (value === "Caught" || value === "RunOut" || value === "Stumped" || value === "CaughtBehind") {
                fielderSection.style.display = "block";
            } else {
                fielderSection.style.display = "none";
            }
        }

        wicketType.addEventListener("change", toggleFielderSection);
        toggleFielderSection();
    </script>
}*@








