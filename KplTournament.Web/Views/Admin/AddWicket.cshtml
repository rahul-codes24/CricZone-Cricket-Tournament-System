                <a asp-action="LiveScoring" asp-controller="Admin" asp-route-id="@Model.Id" class="btn">Back to Live Scoring</a>
            </div>
        </form>
    </div>
</div>*@






















@model KplTournament.Web.Models.Match
@using KplTournament.Web.Models
@using System.Linq

@{
    ViewData["Title"] = "Add Wicket";
}

@if (Model == null)
{
    <div class="alert-error">Match data not found.</div>
    <a asp-action="Index" asp-controller="Admin" class="btn">Back to Admin</a>
    return;
}

@{
    bool teamABatsFirst =
        (Model.TossWinner == Model.TeamA?.Name && Model.TossDecision == "Bat") ||
        (Model.TossWinner == Model.TeamB?.Name && Model.TossDecision == "Bowl");

    var battingTeam = Model.CurrentInnings == 1
        ? (teamABatsFirst ? Model.TeamA : Model.TeamB)
        : (teamABatsFirst ? Model.TeamB : Model.TeamA);

    var bowlingTeam = battingTeam?.Id == Model.TeamAId ? Model.TeamB : Model.TeamA;

    var availableBatsmen = battingTeam?.Players?
        .Where(p => p.Id != Model.StrikerId && p.Id != Model.NonStrikerId)
        .OrderBy(p => p.Name)
        .ToList() ?? new List<Player>();

    var fielders = bowlingTeam?.Players?
        .OrderBy(p => p.Name)
        .ToList() ?? new List<Player>();
}

<h2 class="section-title">Add Wicket</h2>

@if (TempData["Error"] != null)
{
    <div class="alert-error">@TempData["Error"]</div>
}

<div class="score-shell">
    <div class="dark-panel">
        <div class="panel-head">
            <h3>@Model.TeamA?.Name vs @Model.TeamB?.Name</h3>
        </div>

        <div class="panel-body">
            <div class="current-grid">
                <div class="info-box">
                    <div class="info-line"><strong>Venue:</strong> @Model.Venue</div>
                    <div class="info-line"><strong>Current Innings:</strong> @Model.CurrentInnings</div>
                    <div class="info-line"><strong>Score:</strong> @Model.CurrentRuns / @Model.CurrentWickets</div>
                    <div class="info-line"><strong>Overs:</strong> @Model.CurrentOver.@Model.CurrentBall</div>
                </div>

                <div class="info-box">
                    <div class="info-line"><strong>Striker:</strong> @(Model.Striker?.Name ?? "Not Selected")</div>
                    <div class="info-line"><strong>Non-Striker:</strong> @(Model.NonStriker?.Name ?? "Not Selected")</div>
                    <div class="info-line"><strong>Bowler:</strong> @(Model.CurrentBowler?.Name ?? "Not Selected")</div>
                    <div class="info-line"><strong>Batting Team:</strong> @(battingTeam?.Name ?? "N/A")</div>
                    <div class="info-line"><strong>Bowling Team:</strong> @(bowlingTeam?.Name ?? "N/A")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="notice-card notice-warning">
        <h4>Wicket Details</h4>
        <p>Select the out batsman, wicket type, fielder if needed, and next batsman.</p>

        <form asp-action="SaveWicket" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="matchId" value="@Model.Id" />

            <div class="select-grid">
                <div>
                    <label><strong>Out Batsman</strong></label>
                    <select name="outBatsmanId" class="match-select" required>
                        <option value="">-- Select Out Batsman --</option>
                        @if (Model.Striker != null)
                        {
                            <option value="@Model.Striker.Id">@Model.Striker.Name</option>
                        }
                        @if (Model.NonStriker != null)
                        {
                            <option value="@Model.NonStriker.Id">@Model.NonStriker.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label><strong>Wicket Type</strong></label>
                    <select name="wicketType" class="match-select" required>
                        <option value="">-- Select Wicket Type --</option>
                        <option value="Bowled">Bowled</option>
                        <option value="Caught">Caught</option>
                        <option value="LBW">LBW</option>
                        <option value="RunOut">Run Out</option>
                        <option value="Stumped">Stumped</option>
                        <option value="HitWicket">Hit Wicket</option>
                        <option value="CaughtBehind">Caught Behind</option>
                    </select>
                </div>

                <div>
                    <label><strong>Fielder (if required)</strong></label>
                    <select name="fielderId" class="match-select">
                        <option value="">-- Select Fielder --</option>
                        @foreach (var player in fielders)
                        {
                            <option value="@player.Id">@player.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label><strong>Next Batsman</strong></label>
                    <select name="nextBatsmanId" class="match-select">
                        <option value="">-- Select Next Batsman --</option>
                        @foreach (var player in availableBatsmen)
                        {
                            <option value="@player.Id">@player.Name</option>
                        }
                    </select>
                </div>
            </div>

            <p class="helper-text">
                For Bowled/LBW/Hit Wicket, fielder is not needed.
                For Caught, Run Out, Stumped, and Caught Behind, select a fielder.
            </p>

            <div class="button-row">
                <button type="submit" class="btn btn-danger">Save Wicket</button>
                <a asp-action="LiveScoring" asp-controller="Admin" asp-route-id="@Model.Id" class="btn">Back to Live Scoring</a>
            </div>
        </form>
    </div>
</div>