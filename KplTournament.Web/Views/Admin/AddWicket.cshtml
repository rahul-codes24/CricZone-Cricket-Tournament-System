                        @if (Model.NonStriker != null)
                        {
                            <option value="@Model.NonStriker.Id">@Model.NonStriker.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label><strong>Wicket Type</strong></label>
                    <select name="wicketType" class="match-select" required>
                        <option value="">-- Select Wicket Type --</option>
                        <option value="Bowled">Bowled</option>
                        <option value="Caught">Caught</option>
                        <option value="LBW">LBW</option>
                        <option value="Run Out">Run Out</option>
                        <option value="Stumped">Stumped</option>
                        <option value="Hit Wicket">Hit Wicket</option>
                    </select>
                </div>

                <div>
                    <label><strong>Fielder Name (optional)</strong></label>
                    <input type="text" name="fielderName" class="match-input" placeholder="Enter fielder name if needed" />
                </div>

                <div>
                    <label><strong>New Batsman</strong></label>
                    <select name="newBatsmanId" class="match-select" required>
                        <option value="">-- Select New Batsman --</option>
