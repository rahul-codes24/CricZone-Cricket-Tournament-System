@model List<KplTournament.Web.Models.Player>

@{
    ViewData["Title"] = "Players List";
}

<section class="players-list-page">

    <div class="players-list-card">

        <h1>Player List</h1>

        <div class="players-table-wrap">
            <table class="players-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Team</th>
                        <th>Role</th>
                        <th>Captain</th>
                        <th>Vice Captain</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var player in Model)
                        {
                            <tr>
                                <td>@player.Name</td>
                                <td>@player.Team?.Name</td>
                                <td>@player.Role</td>
                                <td>@(player.IsCaptain ? "Yes" : "No")</td>
                                <td>@(player.IsViceCaptain ? "Yes" : "No")</td>
                                <td>
                                    <div class="player-actions">
                                        <a asp-action="EditPlayer" asp-route-id="@player.Id" class="player-btn player-btn-blue">Edit</a>

                                        <form asp-action="DeletePlayer"
                                              asp-route-id="@player.Id"
                                              method="post"
                                              onsubmit="return confirm('Are you sure you want to delete this player?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="player-btn player-btn-red">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="no-data-cell">No players found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

</section>

<style>
    .players-list-page {
        min-height: calc(100vh - 80px);
        padding: 20px 28px;
        background: linear-gradient(rgba(0,0,0,0.38), rgba(0,0,0,0.45)), url('/images/stadium.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .players-list-card {
        max-width: 1000px;
        margin: 0 auto;
        padding: 24px;
        border-radius: 22px;
        background: rgba(255,255,255,0.055);
        backdrop-filter: blur(32px);
        -webkit-backdrop-filter: blur(32px);
        border: 1px solid rgba(255,255,255,0.12);
        box-shadow: 0 22px 55px rgba(0,0,0,0.45);
    }

        .players-list-card h1 {
            margin: 0 0 18px;
            color: #ffffff;
            font-size: 34px;
            font-weight: 1000;
        }

    .players-table-wrap {
        overflow-x: auto;
        border-radius: 18px;
        background: rgba(255,255,255,0.03);
    }

    .players-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .players-table thead {
            background: linear-gradient(90deg, #1d4ed8, #2563eb);
        }

        .players-table th {
            padding: 16px;
            color: #ffffff;
            font-size: 14px;
            font-weight: 900;
            text-align: left;
            white-space: nowrap;
        }

        .players-table td {
            padding: 15px 16px;
            color: #ffffff;
            font-size: 14px;
            font-weight: 600;
            background: rgba(255,255,255,0.045);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            vertical-align: middle;
        }

        .players-table tbody tr:nth-child(even) td {
            background: rgba(255,255,255,0.065);
        }

        .players-table tbody tr:hover td {
            background: rgba(255,255,255,0.12);
        }

    .player-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .player-actions form {
            margin: 0;
        }

    .player-btn {
        height: 34px;
        padding: 0 16px;
        border-radius: 999px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 900;
        cursor: pointer;
    }

    .player-btn-blue {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
    }

    .player-btn-red {
        background: linear-gradient(135deg, #dc2626, #b91c1c);
    }

    .player-btn:hover {
        transform: translateY(-2px);
        color: #ffffff;
    }

    .no-data-cell {
        text-align: center;
        padding: 22px !important;
        color: #ffffff;
    }

    @@media (max-width: 768px) {
        .players-list-page {
            padding: 12px;
        }

        .players-list-card {
            padding: 18px;
        }

            .players-list-card h1 {
                font-size: 28px;
            }
    }
</style>