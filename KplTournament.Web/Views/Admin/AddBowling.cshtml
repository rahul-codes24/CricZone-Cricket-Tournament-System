@{ ViewData["Title"] = "Add Bowling"; }
<section class="form-card">
    <h1>Add Bowling Row</h1>
    <form method="post">
        <input type="hidden" name="MatchId" value="@ViewBag.MatchId" />
        <label>Player</label><select name="PlayerId" asp-items="ViewBag.Players"></select>
        <label>Team</label><select name="TeamId" asp-items="ViewBag.Teams"></select>
        <label>Overs</label><input name="Overs" />
        <label>Runs Given</label><input name="RunsGiven" />
        <label>Wickets</label><input name="Wickets" />
        <label>Maidens</label><input name="Maidens" />
        <button class="btn" type="submit">Save Bowling</button>
    </form>
</section>
