@model KplTournament.Web.Models.Match

@{
    ViewData["Title"] = "Create Match";
}

<section class="match-page">

    <div class="match-card">

        <h1>Create Match</h1>

        <form asp-action="CreateMatch" method="post">

            <div asp-validation-summary="ModelOnly" class="alert-error"></div>

            <div class="form-group">
                <label asp-for="TeamAId">Team A</label>
                <select asp-for="TeamAId" asp-items="ViewBag.Teams" class="form-control">
                    <option value="">-- Select Team A --</option>
                </select>
                <span asp-validation-for="TeamAId" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="TeamBId">Team B</label>
                <select asp-for="TeamBId" asp-items="ViewBag.Teams" class="form-control">
                    <option value="">-- Select Team B --</option>
                </select>
                <span asp-validation-for="TeamBId" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Venue">Venue</label>
                <input asp-for="Venue" class="form-control" placeholder="Enter venue" />
                <span asp-validation-for="Venue" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="OversPerInnings">Overs</label>
                <input asp-for="OversPerInnings" class="form-control" type="number" min="1" />
                <span asp-validation-for="OversPerInnings" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="MatchDate">Match Date</label>
                <input asp-for="MatchDate" class="form-control" type="date" />
                <span asp-validation-for="MatchDate" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="MatchType">Match Type</label>
                <select asp-for="MatchType" class="form-control">
                    <option value="League Match">League Match</option>
                    <option value="Quarter Final Match">Quarter Final Match</option>
                    <option value="Semi Final Match">Semi Final Match</option>
                    <option value="Final Match">Final Match</option>
                    <option value="Other Match">Other Match</option>
                </select>
                <span asp-validation-for="MatchType" class="field-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">Create Match</button>
            </div>

        </form>

    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
<style>
    /* =========================
       CREATE MATCH - TOSS STYLE
    ========================= */

    .match-page {
        min-height: calc(100vh - 80px);
        padding: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.35)), url('/images/stadium.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .match-card {
        width: 100%;
        max-width: 420px;
        padding: 20px 16px;
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(139, 91, 86, .72), rgba(18, 32, 43, .92)) !important;
        backdrop-filter: blur(28px);
        -webkit-backdrop-filter: blur(28px);
        border: none;
        box-shadow: 0 20px 50px rgba(0,0,0,.45);
    }

        .match-card h1 {
            margin: 0 0 16px;
            text-align: center;
            color: #ffffff;
            font-size: 26px;
            font-weight: 1000;
        }

    .match-page .form-group {
        margin-bottom: 12px;
    }

    .match-page label {
        display: block;
        margin-bottom: 6px;
        font-size: 12px;
        font-weight: 800;
        color: #ffffff !important;
    }

    .match-page .form-control {
        width: 100%;
        height: 36px;
        padding: 0 12px;
        background: #ffffff !important;
        color: #111827 !important;
        border: none !important;
        border-radius: 999px !important;
        outline: none;
        font-size: 13px;
        font-weight: 700;
    }

    .match-page select.form-control {
        appearance: auto;
    }

    .match-page .form-control::placeholder {
        color: rgba(17,24,39,0.55);
    }

    .match-page .form-control:focus {
        box-shadow: 0 0 0 3px rgba(96,165,250,.35);
    }

    .match-page .form-actions {
        margin-top: 10px;
    }

    .btn-save {
        width: 100%;
        height: 38px;
        border-radius: 999px;
        border: none;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: #ffffff;
        font-size: 13px;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 8px 20px rgba(34,197,94,0.4);
        transition: 0.2s;
    }

        .btn-save:hover {
            transform: translateY(-2px);
        }

    .field-error,
    .text-danger {
        font-size: 11px;
        color: #fecaca;
    }

    .alert-error {
        background: rgba(239,68,68,0.22);
        color: #fecaca;
        padding: 7px 10px;
        border-radius: 12px;
        margin-bottom: 10px;
        font-size: 11px;
    }

    @@media (max-width: 768px) {
        .match-page {
            padding: 10px;
        }

        .match-card {
            max-width: 300px;
        }
    }
</style>