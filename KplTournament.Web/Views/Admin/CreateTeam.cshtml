@model KplTournament.Web.Models.Team

@{
    ViewData["Title"] = "Add Team";
}

<section class="add-team-page">
    <div class="add-team-card">

        <h1>Add Team</h1>

        <form asp-action="CreateTeam" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert-error"></div>

            <div class="form-group">
                <label asp-for="Name">Team Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter team name" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ShortName">Short Name</label>
                <input asp-for="ShortName" class="form-control" placeholder="Enter short name" />
                <span asp-validation-for="ShortName" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="OwnerName">Owner Name</label>
                <input asp-for="OwnerName" class="form-control" placeholder="Enter owner name" />
                <span asp-validation-for="OwnerName" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="PrimaryColor">Team Color</label>
                <input asp-for="PrimaryColor"
                       type="color"
                       class="form-control color-input"
                       value="@(string.IsNullOrWhiteSpace(Model?.PrimaryColor) ? "#0f172a" : Model.PrimaryColor)" />
                <span asp-validation-for="PrimaryColor" class="field-error"></span>
            </div>

           

            <div class="form-group">
                <label for="logoFile">Team Logo</label>
                <input type="file"
                       name="logoFile"
                       id="logoFile"
                       class="form-control file-input"
                       accept=".jpg,.jpeg,.png,.webp" />
                <small class="text-muted">Allowed: JPG, JPEG, PNG, WEBP. Max 2 MB.</small>
            </div>

            <div class="form-group preview-box">
                <img id="logoPreview" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save-team">Save Team</button>
            </div>
        </form>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById("logoFile").addEventListener("change", function (event) {
            const file = event.target.files[0];
            const preview = document.getElementById("logoPreview");

            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.style.display = "block";
            } else {
                preview.style.display = "none";
            }
        });
    </script>
}

<style>
    /* =========================
       ADD TEAM PAGE - EXACT TOSS STYLE
    ========================= */

    .add-team-page {
        min-height: calc(100vh - 80px);
        padding: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.35)), url('/images/stadium.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .add-team-card {
        width: 100%;
        max-width: 420px;
        padding: 20px 16px;
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(139, 91, 86, .72), rgba(18, 32, 43, .92));
        backdrop-filter: blur(28px);
        -webkit-backdrop-filter: blur(28px);
        border: none;
        box-shadow: 0 20px 50px rgba(0,0,0,.45);
    }

        .add-team-card h1 {
            margin: 0 0 16px;
            text-align: center;
            color: #ffffff;
            font-size: 26px;
            font-weight: 1000;
            letter-spacing: .3px;
        }

    .add-team-page .form-group {
        margin-bottom: 11px;
    }

    .add-team-page label {
        display: block;
        margin-bottom: 6px;
        font-size: 12px;
        font-weight: 800;
        color: #ffffff;
    }

    .add-team-page .form-control {
        width: 100%;
        height: 36px;
        padding: 0 12px;
        background: #ffffff;
        color: #111827;
        border: none;
        border-radius: 999px;
        outline: none;
        font-size: 13px;
        font-weight: 600;
    }

        .add-team-page .form-control::placeholder {
            color: rgba(17,24,39,0.55);
        }

        .add-team-page .form-control:focus {
            box-shadow: 0 0 0 3px rgba(96,165,250,0.35);
        }

    .add-team-page .color-input {
        padding: 5px 10px;
    }

    .add-team-page .file-input {
        padding: 6px 10px;
        font-size: 12px;
    }

    .add-team-page .text-muted {
        display: block;
        margin-top: 5px;
        font-size: 10px;
        color: rgba(255,255,255,0.75);
    }

    .field-error,
    .text-danger {
        font-size: 11px;
        color: #fecaca;
    }

    .add-team-page .form-actions {
        margin-top: 10px;
    }

    .btn-save-team {
        width: 100%;
        height: 38px;
        border-radius: 999px;
        border: none;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: white;
        font-size: 13px;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 8px 20px rgba(34,197,94,0.4);
        transition: 0.2s;
    }

        .btn-save-team:hover {
            transform: translateY(-2px);
        }

    .preview-box {
        text-align: center;
        margin-bottom: 8px !important;
    }

    #logoPreview {
        display: none;
        width: 55px;
        height: 55px;
        margin: 0 auto;
        border-radius: 12px;
        object-fit: cover;
        border: 2px solid rgba(255,255,255,0.35);
    }

    .alert-error {
        background: rgba(239,68,68,0.22);
        color: #fecaca;
        padding: 7px 10px;
        border-radius: 12px;
        margin-bottom: 10px;
        font-size: 11px;
    }

    /* MOBILE */
    @@media (max-width: 768px) {
        .add-team-page {
            padding: 10px;
        }

        .add-team-card {
            max-width: 300px;
        }
    }
</style>